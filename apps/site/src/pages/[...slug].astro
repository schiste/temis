---
import {
  entryDescription,
  entrySlug,
  entryTitle,
  getPageBySlug,
  getPages,
} from "../lib/emdash";
import { portableTextToHtml } from "../lib/portable-text";
import "../styles/global.css";

export async function getStaticPaths() {
  const pages = await getPages();
  return pages.map((page) => ({
    params: { slug: entrySlug(page) },
    props: { page },
  }));
}

const { page } = Astro.props;
const resolvedPage = page ?? (await getPageBySlug(Astro.params.slug ?? ""));
if (!resolvedPage) {
  return Astro.redirect("/404");
}

const title = entryTitle(resolvedPage);
const description = entryDescription(resolvedPage);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} | TEMIS</title>
    {description && <meta name="description" content={description} />}
  </head>
  <body>
    <main class="shell">
      <header class="site-header">
        <a class="brand" href="/">TEMIS</a>
        <nav class="nav" aria-label="Primary">
          <a href="/blog/">Blog</a>
        </nav>
      </header>

      <section class="hero">
        <p class="eyebrow">Page</p>
        <h1>{title}</h1>
        {description && <p class="lede">{description}</p>}
      </section>

      <article
        class="content"
        set:html={portableTextToHtml(resolvedPage.content)}
      />
    </main>
  </body>
</html>
