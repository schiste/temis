---
import BaseLayout from "@temis/design-system/components/BaseLayout.astro";
import PageHero from "@temis/design-system/components/PageHero.astro";
import {
  entryDescription,
  entrySlug,
  entryTitle,
  getPageBySlug,
  getPages,
} from "../lib/emdash";
import { portableTextToHtml } from "../lib/portable-text";

export async function getStaticPaths() {
  const pages = await getPages();
  return pages.map((page) => ({
    params: { slug: entrySlug(page) },
    props: { page },
  }));
}

const { page } = Astro.props;
const resolvedPage = page ?? (await getPageBySlug(Astro.params.slug ?? ""));
if (!resolvedPage) {
  return Astro.redirect("/404");
}

const title = entryTitle(resolvedPage);
const description = entryDescription(resolvedPage);
---

<BaseLayout title={title} description={description}>
  <PageHero eyebrow="Page" title={title} description={description} />

  <article
    class="ds-prose"
    set:html={portableTextToHtml(resolvedPage.content)}
  />
</BaseLayout>
