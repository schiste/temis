---
import PageHero from "@temis/design-system/components/PageHero.astro";
import RichContent from "@temis/design-system/components/RichContent.astro";
import SiteLayout from "../components/SiteLayout.astro";
import {
  entryDescription,
  entrySlug,
  entryTitle,
  getCatchAllPages,
  getPageBySlug,
  getSiteTexts,
} from "../lib/emdash";

export async function getStaticPaths() {
  const pages = await getCatchAllPages();
  return pages.map((page) => ({
    params: { slug: entrySlug(page) },
    props: { page },
  }));
}

const { page } = Astro.props;
const resolvedPage = page ?? (await getPageBySlug(Astro.params.slug ?? ""));
if (!resolvedPage) {
  return Astro.redirect("/404");
}

const title = entryTitle(resolvedPage);
const description = entryDescription(resolvedPage);
const copy = await getSiteTexts({
  pageHeroEyebrow: "Page",
});
---

<SiteLayout title={title} description={description}>
  <PageHero
    eyebrow={copy.pageHeroEyebrow}
    title={title}
    description={description}
  />

  <RichContent as="article" value={resolvedPage.content} />
</SiteLayout>
