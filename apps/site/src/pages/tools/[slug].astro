---
import ContentGraphRail from "../../components/ContentGraphRail.astro";
import SiteLayout from "../../components/SiteLayout.astro";
import {
  getFocusedContentGraphSnapshot,
  toolGraphNodeId,
} from "../../lib/content-graph";
import {
  entryDescription,
  entryBylineHref,
  entryBylineName,
  entryBylineSlug,
  entryExternalUrl,
  entrySlug,
  entryTitle,
  getBylines,
  getPosts,
  getSiteTexts,
  getToolBySlug,
  getTools,
} from "../../lib/emdash";
import { portableTextToHtml } from "../../lib/portable-text";
import { relatedPeopleReferences, relatedRecordIds } from "../../lib/relations";

export async function getStaticPaths() {
  const tools = await getTools();
  return tools.map((tool) => ({
    params: { slug: entrySlug(tool) },
    props: { tool },
  }));
}

const { tool } = Astro.props;
const resolvedTool = tool ?? (await getToolBySlug(Astro.params.slug ?? ""));
if (!resolvedTool) {
  return Astro.redirect("/404");
}

const title = entryTitle(resolvedTool);
const description = entryDescription(resolvedTool);
const copy = await getSiteTexts({
  toolActivityHeading: "Repository activity",
  toolConnectedHeading: "Connected reading",
  toolDefaultBranchLabel: "Default branch",
  toolDocumentationLabel: "Documentation",
  toolEditorialConfidenceLabel: "Editorial confidence",
  toolForksLabel: "Forks",
  toolGraphHeading: "Navigation graph",
  toolGraphLabel: "Graph navigation from this tool",
  toolHeroEyebrow: "Tool dossier",
  toolImportantLinksHeading: "Important links",
  toolLanguageLabel: "Language",
  toolLastCommitLabel: "Last commit",
  toolLicenseLabel: "License",
  toolMaintenanceLabel: "Maintenance",
  toolOpenIssuesLabel: "Open issues",
  toolOpenPrivacyHeading: "Open-source and privacy",
  toolOpenToolLabel: "Open tool",
  toolOverviewHeading: "Overview",
  toolPeopleHeading: "People",
  toolPrivacyLabel: "Privacy note",
  toolRepositoryLabel: "Repository",
  toolStarsLabel: "Stars",
  toolTechnicalMaturityLabel: "Technical maturity",
  toolWebsiteLabel: "Website",
});
const graph = await getFocusedContentGraphSnapshot(
  toolGraphNodeId(resolvedTool),
);
const [posts, bylines] = await Promise.all([getPosts(), getBylines()]);
const toolUrl = entryExternalUrl(resolvedTool.tool_url);
const repositoryUrl = entryExternalUrl(resolvedTool.repository_url);
const documentationUrl = entryExternalUrl(resolvedTool.documentation_url);
const license = resolvedTool.license?.trim();
const privacyNote = resolvedTool.privacy_note?.trim();
const technicalMaturity =
  resolvedTool.technical_maturity?.trim() || resolvedTool.maturity?.trim();
const editorialConfidence = resolvedTool.editorial_confidence?.trim();
const github = resolvedTool.github;
const lastCommitDateTime = github?.lastCommitAt;
const lastCommitDate = lastCommitDateTime ? new Date(lastCommitDateTime) : null;
const lastCommitLabel =
  lastCommitDate && !Number.isNaN(lastCommitDate.valueOf())
    ? new Intl.DateTimeFormat("en-GB", {
        day: "2-digit",
        month: "short",
        timeZone: "UTC",
        year: "numeric",
      }).format(lastCommitDate)
    : lastCommitDateTime?.slice(0, 10);

function hostLabel(value: string | null | undefined) {
  if (!value) return "";

  try {
    return new URL(value).hostname.replace(/^www\./, "");
  } catch {
    return value;
  }
}

function numberLabel(value: number | null | undefined) {
  return typeof value === "number"
    ? new Intl.NumberFormat("en-US").format(value)
    : "";
}

function maintenanceSignal(date: Date | null, label: string | undefined) {
  if (!date || Number.isNaN(date.valueOf())) {
    return {
      detail: "No public commit signal",
      tone: "unknown",
      value: "Unknown",
    };
  }

  const days = Math.max(
    0,
    Math.floor((Date.now() - date.getTime()) / 86_400_000),
  );
  if (days <= 30) {
    return {
      detail: label ? `Last commit ${label}` : "Recent commit",
      tone: "active",
      value: "Active",
    };
  }
  if (days <= 180) {
    return {
      detail: label ? `Last commit ${label}` : "Recent commit",
      tone: "recent",
      value: "Recent",
    };
  }
  if (days <= 365) {
    return {
      detail: label ? `Last commit ${label}` : "Older commit",
      tone: "quiet",
      value: "Quiet",
    };
  }

  return {
    detail: label ? `Last commit ${label}` : "Older commit",
    tone: "dormant",
    value: "Dormant",
  };
}

const maintenance = maintenanceSignal(lastCommitDate, lastCommitLabel);
type ToolSignalItem = {
  detail?: string;
  href?: string;
  label: string;
  tone?: string;
  value: string;
};
const importantLinks = [
  toolUrl
    ? {
        detail: hostLabel(toolUrl),
        href: toolUrl,
        label: copy.toolOpenToolLabel,
        variant: "primary",
      }
    : null,
  repositoryUrl
    ? {
        detail: github?.fullName ?? hostLabel(repositoryUrl),
        href: repositoryUrl,
        label: copy.toolRepositoryLabel,
        variant: "secondary",
      }
    : null,
  documentationUrl
    ? {
        detail: hostLabel(documentationUrl),
        href: documentationUrl,
        label: copy.toolDocumentationLabel,
        variant: "secondary",
      }
    : null,
].filter(
  (
    item,
  ): item is {
    detail: string;
    href: string;
    label: string;
    variant: "primary" | "secondary";
  } => Boolean(item),
);
const activityItemCandidates: (ToolSignalItem | null)[] = [
  {
    detail: maintenance.detail,
    label: copy.toolMaintenanceLabel,
    tone: maintenance.tone,
    value: maintenance.value,
  },
  github?.fullName
    ? {
        href: repositoryUrl ?? github.repositoryUrl,
        label: copy.toolRepositoryLabel,
        value: github.fullName,
      }
    : null,
  lastCommitLabel
    ? {
        href: github?.lastCommitUrl,
        label: copy.toolLastCommitLabel,
        value: lastCommitLabel,
      }
    : null,
  github?.defaultBranch
    ? {
        label: copy.toolDefaultBranchLabel,
        value: github.defaultBranch,
      }
    : null,
  github?.primaryLanguage
    ? {
        label: copy.toolLanguageLabel,
        value: github.primaryLanguage,
      }
    : null,
  numberLabel(github?.stars)
    ? {
        label: copy.toolStarsLabel,
        value: numberLabel(github?.stars),
      }
    : null,
  numberLabel(github?.forks)
    ? {
        label: copy.toolForksLabel,
        value: numberLabel(github?.forks),
      }
    : null,
  numberLabel(github?.openIssues)
    ? {
        label: copy.toolOpenIssuesLabel,
        value: numberLabel(github?.openIssues),
      }
    : null,
];
const activityItems = activityItemCandidates.filter(
  (item): item is ToolSignalItem => Boolean(item),
);
const trustItems = [
  license
    ? {
        label: copy.toolLicenseLabel,
        value: license,
      }
    : null,
  privacyNote
    ? {
        label: copy.toolPrivacyLabel,
        value: privacyNote,
      }
    : null,
  technicalMaturity
    ? {
        label: copy.toolTechnicalMaturityLabel,
        value: technicalMaturity,
      }
    : null,
  editorialConfidence
    ? {
        label: copy.toolEditorialConfidenceLabel,
        value: editorialConfidence,
      }
    : null,
].filter((item): item is { label: string; value: string } => Boolean(item));
const relatedPostIds = new Set(relatedRecordIds(resolvedTool.related_articles));
const relatedPosts = posts
  .filter((post) => post.id && relatedPostIds.has(post.id))
  .map((post) => ({
    description: entryDescription(post),
    href: `/blog/${entrySlug(post)}/`,
    label: entryTitle(post),
  }));
const bylineById = new Map(bylines.map((byline) => [byline.id, byline]));
const bylineBySlug = new Map(
  bylines.map((byline) => [entryBylineSlug(byline), byline]),
);
const personReferences = relatedPeopleReferences(resolvedTool.related_people);
const peopleByKey = new Map<
  string,
  { detail?: string; href?: string; label: string }
>();
const primaryByline = resolvedTool.primary_byline_id
  ? bylineById.get(resolvedTool.primary_byline_id)
  : null;

if (primaryByline) {
  peopleByKey.set(entryBylineSlug(primaryByline), {
    detail: "Primary maintainer",
    href: entryBylineHref(primaryByline),
    label: entryBylineName(primaryByline),
  });
}

for (const person of personReferences) {
  const slug = person.label
    .toLowerCase()
    .normalize("NFD")
    .replace(/[\u0300-\u036f]/g, "")
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-+|-+$/g, "");
  const byline = bylineBySlug.get(slug);
  peopleByKey.set(slug || person.label, {
    detail: person.detail,
    href: byline ? entryBylineHref(byline) : undefined,
    label: byline ? entryBylineName(byline) : person.label,
  });
}

const peopleLinks = [...peopleByKey.values()];
---

<SiteLayout title={title} description={description}>
  <div class="ds-content-page">
    <article class="ds-content-main ds-tool-record ds-tool-record--dossier">
      <header class="ds-tool-hero">
        <div class="ds-tool-hero__identity">
          <p class="ds-eyebrow">{copy.toolHeroEyebrow}</p>
          <h1 class="ds-tool-title">{title}</h1>
          <p class="ds-tool-summary">{description}</p>
        </div>
      </header>

      <section class="ds-tool-section ds-tool-section--overview">
        <div class="ds-tool-section__header">
          <h2>{copy.toolOverviewHeading}</h2>
        </div>
        <div
          class="ds-prose ds-tool-prose"
          set:html={portableTextToHtml(resolvedTool.description)}
        />
      </section>

      {
        importantLinks.length > 0 && (
          <section class="ds-tool-section">
            <div class="ds-tool-section__header">
              <h2>{copy.toolImportantLinksHeading}</h2>
            </div>
            <nav class="ds-tool-actions" aria-label="Tool links">
              {importantLinks.map((action) => (
                <a
                  class:list={[
                    "ds-tool-action",
                    action.variant === "primary" && "ds-tool-action--primary",
                  ]}
                  href={action.href}
                >
                  <span>{action.label}</span>
                  <strong>{action.detail}</strong>
                </a>
              ))}
            </nav>
          </section>
        )
      }

      {
        activityItems.length > 0 && (
          <section class="ds-tool-section">
            <div class="ds-tool-section__header">
              <h2>{copy.toolActivityHeading}</h2>
            </div>
            <dl class="ds-tool-signal-grid">
              {activityItems.map((item) => (
                <div data-tone={item.tone}>
                  <dt>{item.label}</dt>
                  <dd>
                    {item.href ? (
                      <a href={item.href}>{item.value}</a>
                    ) : (
                      item.value
                    )}
                  </dd>
                  {item.detail && <p>{item.detail}</p>}
                </div>
              ))}
            </dl>
          </section>
        )
      }

      {
        trustItems.length > 0 && (
          <section class="ds-tool-section">
            <div class="ds-tool-section__header">
              <h2>{copy.toolOpenPrivacyHeading}</h2>
            </div>
            <dl class="ds-tool-definition-list">
              {trustItems.map((item) => (
                <div>
                  <dt>{item.label}</dt>
                  <dd>{item.value}</dd>
                </div>
              ))}
            </dl>
          </section>
        )
      }

      {
        relatedPosts.length > 0 && (
          <section class="ds-tool-section">
            <div class="ds-tool-section__header">
              <h2>{copy.toolConnectedHeading}</h2>
            </div>
            <div class="ds-tool-link-list">
              {relatedPosts.map((post) => (
                <a class="ds-tool-link-card" href={post.href}>
                  <span>Field note</span>
                  <strong>{post.label}</strong>
                  {post.description && <em>{post.description}</em>}
                </a>
              ))}
            </div>
          </section>
        )
      }

      {
        peopleLinks.length > 0 && (
          <section class="ds-tool-section">
            <div class="ds-tool-section__header">
              <h2>{copy.toolPeopleHeading}</h2>
            </div>
            <div class="ds-tool-link-list ds-tool-link-list--people">
              {peopleLinks.map((person) =>
                person.href ? (
                  <a class="ds-tool-link-card" href={person.href}>
                    <span>Person</span>
                    <strong>{person.label}</strong>
                    {person.detail && <em>{person.detail}</em>}
                  </a>
                ) : (
                  <div class="ds-tool-link-card">
                    <span>Person</span>
                    <strong>{person.label}</strong>
                    {person.detail && <em>{person.detail}</em>}
                  </div>
                ),
              )}
            </div>
          </section>
        )
      }
    </article>
    <ContentGraphRail
      graph={graph}
      heading={copy.toolGraphHeading}
      label={copy.toolGraphLabel}
    />
  </div>
</SiteLayout>
