---
import RichContent from "@temis/design-system/components/RichContent.astro";
import ContentGraphRail from "../../components/ContentGraphRail.astro";
import SiteLayout from "../../components/SiteLayout.astro";
import {
  getFocusedContentGraphSnapshot,
  toolGraphNodeId,
} from "../../lib/content-graph";
import {
  entryDescription,
  entrySlug,
  entryTitle,
  getBylines,
  getPosts,
  getSiteTexts,
  getToolBySlug,
  getTools,
} from "../../lib/emdash";
import { buildToolDossier } from "../../lib/tool-dossier";

export async function getStaticPaths() {
  const tools = await getTools();
  return tools.map((tool) => ({
    params: { slug: entrySlug(tool) },
    props: { tool },
  }));
}

const { tool } = Astro.props;
const resolvedTool = tool ?? (await getToolBySlug(Astro.params.slug ?? ""));
if (!resolvedTool) {
  return Astro.redirect("/404");
}

const title = entryTitle(resolvedTool);
const description = entryDescription(resolvedTool);
const copy = await getSiteTexts({
  toolActivityHeading: "Repository activity",
  toolConnectedHeading: "Connected reading",
  toolDefaultBranchLabel: "Default branch",
  toolDocumentationLabel: "Documentation",
  toolEditorialConfidenceLabel: "Editorial confidence",
  toolForksLabel: "Forks",
  toolGraphHeading: "Navigation graph",
  toolGraphLabel: "Graph navigation from this tool",
  toolHeroEyebrow: "Tool dossier",
  toolImportantLinksHeading: "Important links",
  toolLanguageLabel: "Language",
  toolLastCommitLabel: "Last commit",
  toolLicenseLabel: "License",
  toolMaintenanceLabel: "Maintenance",
  toolOpenIssuesLabel: "Open issues",
  toolOpenPrivacyHeading: "Open-source and privacy",
  toolOpenToolLabel: "Open tool",
  toolOverviewHeading: "Overview",
  toolPeopleHeading: "People",
  toolPrivacyLabel: "Privacy note",
  toolRepositoryLabel: "Repository",
  toolScreenshotHeading: "Interface snapshot",
  toolStarsLabel: "Stars",
  toolTechnicalMaturityLabel: "Technical maturity",
  toolWebsiteLabel: "Website",
});
const graph = await getFocusedContentGraphSnapshot(
  toolGraphNodeId(resolvedTool),
);
const [posts, bylines] = await Promise.all([getPosts(), getBylines()]);
const {
  activityItems,
  importantLinks,
  peopleLinks,
  relatedPosts,
  screenshotAlt,
  screenshotCaption,
  screenshotLicense,
  screenshotUrl,
  trustItems,
} = buildToolDossier(resolvedTool, posts, bylines, copy);
---

<SiteLayout title={title} description={description}>
  <div class="ds-content-page">
    <article class="ds-content-main ds-tool-record ds-tool-record--dossier">
      <header class="ds-tool-hero">
        <div class="ds-tool-hero__identity">
          <p class="ds-eyebrow">{copy.toolHeroEyebrow}</p>
          <h1 class="ds-tool-title">{title}</h1>
          <p class="ds-tool-summary">{description}</p>
        </div>
      </header>

      <section class="ds-tool-section ds-tool-section--overview">
        <div class="ds-tool-section__header">
          <h2>{copy.toolOverviewHeading}</h2>
        </div>
        <RichContent value={resolvedTool.description} class="ds-tool-prose" />
      </section>

      {
        screenshotUrl && (
          <section class="ds-tool-section ds-tool-section--media">
            <div class="ds-tool-section__header">
              <h2>{copy.toolScreenshotHeading}</h2>
            </div>
            <figure class="ds-media-frame ds-media-frame--screenshot">
              {(screenshotCaption || screenshotLicense) && (
                <figcaption>
                  {screenshotCaption && <span>{screenshotCaption}</span>}
                  {screenshotLicense && (
                    <small>License: {screenshotLicense}</small>
                  )}
                </figcaption>
              )}
              <img
                class="ds-media-frame__image"
                src={screenshotUrl}
                alt={screenshotAlt}
                width="960"
                height="690"
                loading="lazy"
                decoding="async"
              />
            </figure>
          </section>
        )
      }

      {
        importantLinks.length > 0 && (
          <section class="ds-tool-section">
            <div class="ds-tool-section__header">
              <h2>{copy.toolImportantLinksHeading}</h2>
            </div>
            <nav class="ds-tool-actions" aria-label="Tool links">
              {importantLinks.map((action) => (
                <a
                  class:list={[
                    "ds-tool-action",
                    action.variant === "primary" && "ds-tool-action--primary",
                  ]}
                  href={action.href}
                >
                  <span>{action.label}</span>
                  <strong>{action.detail}</strong>
                </a>
              ))}
            </nav>
          </section>
        )
      }

      {
        activityItems.length > 0 && (
          <section class="ds-tool-section">
            <div class="ds-tool-section__header">
              <h2>{copy.toolActivityHeading}</h2>
            </div>
            <dl class="ds-tool-signal-grid">
              {activityItems.map((item) => (
                <div data-tone={item.tone}>
                  <dt>{item.label}</dt>
                  <dd>
                    {item.href ? (
                      <a href={item.href}>{item.value}</a>
                    ) : (
                      item.value
                    )}
                  </dd>
                  {item.detail && <p>{item.detail}</p>}
                </div>
              ))}
            </dl>
          </section>
        )
      }

      {
        trustItems.length > 0 && (
          <section class="ds-tool-section">
            <div class="ds-tool-section__header">
              <h2>{copy.toolOpenPrivacyHeading}</h2>
            </div>
            <dl class="ds-tool-definition-list">
              {trustItems.map((item) => (
                <div>
                  <dt>{item.label}</dt>
                  <dd>{item.value}</dd>
                </div>
              ))}
            </dl>
          </section>
        )
      }

      {
        relatedPosts.length > 0 && (
          <section class="ds-tool-section">
            <div class="ds-tool-section__header">
              <h2>{copy.toolConnectedHeading}</h2>
            </div>
            <div class="ds-tool-link-list">
              {relatedPosts.map((post) => (
                <a class="ds-tool-link-card" href={post.href}>
                  <span>Field note</span>
                  <strong>{post.label}</strong>
                  {post.description && <em>{post.description}</em>}
                </a>
              ))}
            </div>
          </section>
        )
      }

      {
        peopleLinks.length > 0 && (
          <section class="ds-tool-section">
            <div class="ds-tool-section__header">
              <h2>{copy.toolPeopleHeading}</h2>
            </div>
            <div class="ds-tool-link-list ds-tool-link-list--people">
              {peopleLinks.map((person) =>
                person.href ? (
                  <a class="ds-tool-link-card" href={person.href}>
                    <span>Person</span>
                    <strong>{person.label}</strong>
                    {person.detail && <em>{person.detail}</em>}
                  </a>
                ) : (
                  <div class="ds-tool-link-card">
                    <span>Person</span>
                    <strong>{person.label}</strong>
                    {person.detail && <em>{person.detail}</em>}
                  </div>
                ),
              )}
            </div>
          </section>
        )
      }
    </article>
    <ContentGraphRail
      graph={graph}
      heading={copy.toolGraphHeading}
      label={copy.toolGraphLabel}
    />
  </div>
</SiteLayout>
