---
import MetadataRow from "@temis/design-system/components/MetadataRow.astro";
import PageHero from "@temis/design-system/components/PageHero.astro";
import ContentGraphRail from "../../components/ContentGraphRail.astro";
import SiteLayout from "../../components/SiteLayout.astro";
import {
  getFocusedContentGraphSnapshot,
  toolGraphNodeId,
} from "../../lib/content-graph";
import {
  entryDescription,
  entryExternalUrl,
  entrySlug,
  entryTitle,
  getSiteTexts,
  getToolBySlug,
  getTools,
} from "../../lib/emdash";
import { portableTextToHtml } from "../../lib/portable-text";

export async function getStaticPaths() {
  const tools = await getTools();
  return tools.map((tool) => ({
    params: { slug: entrySlug(tool) },
    props: { tool },
  }));
}

const { tool } = Astro.props;
const resolvedTool = tool ?? (await getToolBySlug(Astro.params.slug ?? ""));
if (!resolvedTool) {
  return Astro.redirect("/404");
}

const title = entryTitle(resolvedTool);
const description = entryDescription(resolvedTool);
const copy = await getSiteTexts({
  toolDocumentationLabel: "Documentation",
  toolEditorialConfidenceLabel: "Editorial confidence",
  toolGraphHeading: "Navigation graph",
  toolGraphLabel: "Graph navigation from this tool",
  toolHeroEyebrow: "Tool",
  toolLanguageLabel: "Language",
  toolLastCommitLabel: "Last commit",
  toolLicenseLabel: "License",
  toolOpenPrivacyHeading: "Open-source and privacy",
  toolPrivacyLabel: "Privacy note",
  toolRepositoryLabel: "Repository",
  toolTechnicalMaturityLabel: "Technical maturity",
  toolWebsiteLabel: "Website",
});
const graph = await getFocusedContentGraphSnapshot(
  toolGraphNodeId(resolvedTool),
);
const toolUrl = entryExternalUrl(resolvedTool.tool_url);
const repositoryUrl = entryExternalUrl(resolvedTool.repository_url);
const documentationUrl = entryExternalUrl(resolvedTool.documentation_url);
const license = resolvedTool.license?.trim();
const privacyNote = resolvedTool.privacy_note?.trim();
const technicalMaturity =
  resolvedTool.technical_maturity?.trim() || resolvedTool.maturity?.trim();
const editorialConfidence = resolvedTool.editorial_confidence?.trim();
const github = resolvedTool.github;
const lastCommitDateTime = github?.lastCommitAt;
const lastCommitDate = lastCommitDateTime ? new Date(lastCommitDateTime) : null;
const lastCommitLabel =
  lastCommitDate && !Number.isNaN(lastCommitDate.valueOf())
    ? new Intl.DateTimeFormat("en-GB", {
        day: "2-digit",
        month: "short",
        timeZone: "UTC",
        year: "numeric",
      }).format(lastCommitDate)
    : lastCommitDateTime?.slice(0, 10);
const metadataItems = [
  toolUrl
    ? {
        href: toolUrl,
        label: copy.toolWebsiteLabel,
        value: copy.toolWebsiteLabel,
      }
    : null,
  repositoryUrl
    ? {
        href: repositoryUrl,
        label: copy.toolRepositoryLabel,
        value: copy.toolRepositoryLabel,
      }
    : null,
  documentationUrl
    ? {
        href: documentationUrl,
        label: copy.toolDocumentationLabel,
        value: copy.toolDocumentationLabel,
      }
    : null,
  license
    ? {
        label: copy.toolLicenseLabel,
        value: license,
      }
    : null,
  technicalMaturity
    ? {
        label: copy.toolTechnicalMaturityLabel,
        value: technicalMaturity,
      }
    : null,
  editorialConfidence
    ? {
        label: copy.toolEditorialConfidenceLabel,
        value: editorialConfidence,
      }
    : null,
  github?.primaryLanguage
    ? {
        label: copy.toolLanguageLabel,
        value: github.primaryLanguage,
      }
    : null,
  lastCommitLabel
    ? {
        href: github?.lastCommitUrl,
        label: copy.toolLastCommitLabel,
        value: lastCommitLabel,
      }
    : null,
].filter((item): item is { href?: string; label: string; value: string } =>
  Boolean(item),
);
const openPrivacyItems = [
  license
    ? {
        label: copy.toolLicenseLabel,
        value: license,
      }
    : null,
  privacyNote
    ? {
        label: copy.toolPrivacyLabel,
        value: privacyNote,
      }
    : null,
].filter((item): item is { label: string; value: string } => Boolean(item));
---

<SiteLayout title={title} description={description}>
  <div class="ds-content-page">
    <article class="ds-content-main ds-tool-record">
      <PageHero
        eyebrow={copy.toolHeroEyebrow}
        title={title}
        description={description}
      />
      <MetadataRow items={metadataItems} />
      {
        openPrivacyItems.length > 0 && (
          <section class="ds-tool-record__panel">
            <h2>{copy.toolOpenPrivacyHeading}</h2>
            <dl>
              {openPrivacyItems.map((item) => (
                <div>
                  <dt>{item.label}</dt>
                  <dd>{item.value}</dd>
                </div>
              ))}
            </dl>
          </section>
        )
      }
      <div
        class="ds-prose"
        set:html={portableTextToHtml(resolvedTool.description)}
      />
    </article>
    <ContentGraphRail
      graph={graph}
      heading={copy.toolGraphHeading}
      label={copy.toolGraphLabel}
    />
  </div>
</SiteLayout>
