---
import MetadataRow from "@temis/design-system/components/MetadataRow.astro";
import PageHero from "@temis/design-system/components/PageHero.astro";
import RichContent from "@temis/design-system/components/RichContent.astro";
import ContentGraphRail from "../../components/ContentGraphRail.astro";
import SiteLayout from "../../components/SiteLayout.astro";
import {
  getFocusedContentGraphSnapshot,
  postGraphNodeId,
} from "../../lib/content-graph";
import {
  entryAuthorHref,
  entryAuthorName,
  entryContentType,
  entryDescription,
  entryExternalUrl,
  entryPublishedDateLabel,
  entryPublishedDateTime,
  entrySlug,
  entryTitle,
  getPostBySlug,
  getPosts,
  getSiteTexts,
} from "../../lib/emdash";

export async function getStaticPaths() {
  const posts = await getPosts();
  return posts.map((post) => ({
    params: { slug: entrySlug(post) },
    props: { post },
  }));
}

const { post } = Astro.props;
const resolvedPost = post ?? (await getPostBySlug(Astro.params.slug ?? ""));
if (!resolvedPost) {
  return Astro.redirect("/404");
}

const title = entryTitle(resolvedPost);
const description = entryDescription(resolvedPost);
const copy = await getSiteTexts({
  postGraphHeading: "Navigation graph",
  postGraphLabel: "Graph navigation from this article",
  postAuthorLabel: "Author",
  postContentTypeLabel: "Type",
  postHeroEyebrow: "Article",
  postLicenseLabel: "License",
  postPublishedLabel: "Published",
  postSourceLabel: "Source",
  postStatusLabel: "Status",
  postStatusValue: "Published content",
});
const graph = await getFocusedContentGraphSnapshot(
  postGraphNodeId(resolvedPost),
);
const authorName = entryAuthorName(resolvedPost);
const authorHref = entryAuthorHref(resolvedPost);
const sourceUrl = entryExternalUrl(resolvedPost.source_url);
const licenseUrl = entryExternalUrl(resolvedPost.content_license_url);
const metadataItems = [
  authorName
    ? {
        href: authorHref ?? undefined,
        label: copy.postAuthorLabel,
        value: authorName,
      }
    : null,
  { label: copy.postStatusLabel, value: copy.postStatusValue },
  {
    label: copy.postContentTypeLabel,
    value: entryContentType(resolvedPost),
  },
  {
    label: copy.postPublishedLabel,
    value: entryPublishedDateLabel(resolvedPost),
  },
  resolvedPost.source_title && sourceUrl
    ? {
        href: sourceUrl,
        label: copy.postSourceLabel,
        value: resolvedPost.source_title,
      }
    : null,
  resolvedPost.content_license
    ? {
        href: licenseUrl ?? undefined,
        label: copy.postLicenseLabel,
        value: resolvedPost.content_license,
      }
    : null,
].filter((item): item is { href?: string; label: string; value: string } =>
  Boolean(item),
);
---

<SiteLayout title={title} description={description}>
  <div class="ds-content-page">
    <article class="ds-content-main ds-post-main">
      <PageHero
        eyebrow={copy.postHeroEyebrow}
        title={title}
        description={description}
      />
      <MetadataRow items={metadataItems} />
      {
        entryPublishedDateTime(resolvedPost) && (
          <time
            class="ds-visually-hidden"
            datetime={entryPublishedDateTime(resolvedPost) ?? undefined}
          >
            {entryPublishedDateLabel(resolvedPost)}
          </time>
        )
      }
      <RichContent value={resolvedPost.content} variant="article" />
    </article>
    <ContentGraphRail
      graph={graph}
      heading={copy.postGraphHeading}
      label={copy.postGraphLabel}
    />
  </div>
</SiteLayout>
