---
import MetadataRow from "@temis/design-system/components/MetadataRow.astro";
import PageHero from "@temis/design-system/components/PageHero.astro";
import SiteLayout from "../../components/SiteLayout.astro";
import {
  entryDescription,
  entrySlug,
  entryTitle,
  getPostBySlug,
  getPosts,
  getSiteTexts,
} from "../../lib/emdash";
import { portableTextToHtml } from "../../lib/portable-text";

export async function getStaticPaths() {
  const posts = await getPosts();
  return posts.map((post) => ({
    params: { slug: entrySlug(post) },
    props: { post },
  }));
}

const { post } = Astro.props;
const resolvedPost = post ?? (await getPostBySlug(Astro.params.slug ?? ""));
if (!resolvedPost) {
  return Astro.redirect("/404");
}

const title = entryTitle(resolvedPost);
const description = entryDescription(resolvedPost);
const copy = await getSiteTexts({
  postHeroEyebrow: "Article",
  postStatusLabel: "Status",
  postStatusValue: "Published content",
});
---

<SiteLayout title={title} description={description}>
  <article>
    <PageHero
      eyebrow={copy.postHeroEyebrow}
      title={title}
      description={description}
    />
    <MetadataRow
      items={[{ label: copy.postStatusLabel, value: copy.postStatusValue }]}
    />
    <div class="ds-prose" set:html={portableTextToHtml(resolvedPost.content)} />
  </article>
</SiteLayout>
