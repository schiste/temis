---
import MetadataRow from "@temis/design-system/components/MetadataRow.astro";
import PageHero from "@temis/design-system/components/PageHero.astro";
import SiteLayout from "../../components/SiteLayout.astro";
import {
  entryDescription,
  entrySlug,
  entryTitle,
  getPostBySlug,
  getPosts,
} from "../../lib/emdash";
import { portableTextToHtml } from "../../lib/portable-text";

export async function getStaticPaths() {
  const posts = await getPosts();
  return posts.map((post) => ({
    params: { slug: entrySlug(post) },
    props: { post },
  }));
}

const { post } = Astro.props;
const resolvedPost = post ?? (await getPostBySlug(Astro.params.slug ?? ""));
if (!resolvedPost) {
  return Astro.redirect("/404");
}

const title = entryTitle(resolvedPost);
const description = entryDescription(resolvedPost);
---

<SiteLayout title={title} description={description}>
  <article>
    <PageHero eyebrow="Article" title={title} description={description} />
    <MetadataRow items={[{ label: "Status", value: "Published content" }]} />
    <div class="ds-prose" set:html={portableTextToHtml(resolvedPost.content)} />
  </article>
</SiteLayout>
