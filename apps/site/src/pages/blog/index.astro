---
import FieldNoteRow from "@temis/design-system/components/FieldNoteRow.astro";
import PageHero from "@temis/design-system/components/PageHero.astro";
import SiteLayout from "../../components/SiteLayout.astro";
import {
  entryAuthorHref,
  entryAuthorName,
  entryDescription,
  entryPublishedDateLabel,
  entryPublishedDateTime,
  entrySlug,
  entryTitle,
  getPageBySlug,
  getPosts,
  getSiteTexts,
} from "../../lib/emdash";
import { portableTextToHtml } from "../../lib/portable-text";

const page = await getPageBySlug("blog");
const posts = await getPosts();
const copy = await getSiteTexts({
  blogHeroEyebrow: "Articles",
  blogListFallbackAuthor: "Team publication",
  blogListAuthorHeading: "Author",
  blogListDateHeading: "Published",
  blogListIndexHeading: "No.",
  blogListTaxonomyHeading: "Type / tags",
  blogListTitleHeading: "Title",
  blogListType: "Essay",
  blogMissingDescription: "Published TEMIS articles.",
  blogMissingTitle: "Published articles",
});
const title = page ? entryTitle(page) : copy.blogMissingTitle;
const description = page ? entryDescription(page) : copy.blogMissingDescription;
---

<SiteLayout title={title} description={description}>
  <PageHero
    eyebrow={copy.blogHeroEyebrow}
    title={title}
    description={description}
  />

  {
    page?.content && (
      <article class="ds-prose" set:html={portableTextToHtml(page.content)} />
    )
  }

  <section class="ds-field-notes" aria-label={title}>
    <div class="ds-field-notes__header" aria-hidden="true">
      <span>{copy.blogListIndexHeading}</span>
      <span>{copy.blogListTitleHeading}</span>
      <span>{copy.blogListDateHeading}</span>
      <span>{copy.blogListAuthorHeading}</span>
      <span>{copy.blogListTaxonomyHeading}</span>
    </div>
    {
      posts.map((post, index) => (
        <FieldNoteRow
          authorHref={entryAuthorHref(post) ?? undefined}
          authorName={entryAuthorName(post) ?? undefined}
          contentType={copy.blogListType}
          description={entryDescription(post)}
          fallbackAuthorName={copy.blogListFallbackAuthor}
          href={`/blog/${entrySlug(post)}/`}
          index={(index + 1).toString().padStart(2, "0")}
          publishedDate={entryPublishedDateLabel(post)}
          publishedDateTime={entryPublishedDateTime(post) ?? undefined}
          title={entryTitle(post)}
        />
      ))
    }
  </section>
</SiteLayout>
