---
import PageHero from "@temis/design-system/components/PageHero.astro";
import RichContent from "@temis/design-system/components/RichContent.astro";
import SiteLayout from "../components/SiteLayout.astro";
import {
  entryDescription,
  entryTitle,
  getPageBySlug,
  getSiteTexts,
} from "../lib/emdash";

const page = await getPageBySlug("about");
const copy = await getSiteTexts({
  aboutHeroEyebrow: "About",
  aboutMissingDescription: "TEMIS is a public map of a technical commons.",
  aboutMissingTitle: "About",
});
const title = page ? entryTitle(page) : copy.aboutMissingTitle;
const description = page
  ? entryDescription(page)
  : copy.aboutMissingDescription;
---

<SiteLayout title={title} description={description}>
  <PageHero
    eyebrow={copy.aboutHeroEyebrow}
    title={title}
    description={description}
  />

  {page?.content && <RichContent as="article" value={page.content} />}
</SiteLayout>
