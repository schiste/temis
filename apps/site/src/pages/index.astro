---
import Card from "@temis/design-system/components/Card.astro";
import PageHero from "@temis/design-system/components/PageHero.astro";
import SiteLayout from "../components/SiteLayout.astro";
import {
  blogHref,
  entryAuthorName,
  entryDescription,
  entryTitle,
  getHomePage,
  getPosts,
  getSiteTexts,
} from "../lib/emdash";

const page = await getHomePage();
const posts = await getPosts();
const copy = await getSiteTexts({
  articleCardEyebrow: "Article",
  homeEssaysCardDescription:
    "Essays and tool announcements from people exploring open knowledge after AI.",
  homeEssaysCardEyebrow: "Essays",
  homeEssaysCardTitle: "Read the field notes",
  homeFeaturedEyebrow: "Latest publication",
  homeFeaturedHeading: "Now reading",
  homeHeroEyebrow: "Public map of a technical commons",
  homeLatestHeading: "More to read",
  homeMissingDescription:
    "An exploratory public map for open knowledge work in a post-AI world.",
  homeMissingTitle: "TEMIS",
  homeNavigationHeading: "Explore the map",
  homePeopleCardDescription:
    "Author pages connect published work to the people and teams behind it.",
  homePeopleCardEyebrow: "People",
  homePeopleCardTitle: "Find the authors",
  homeTopicsCardDescription:
    "Follow topic routes across essays, tools, and people as the map takes shape.",
  homeTopicsCardEyebrow: "Topic graph",
  homeTopicsCardTitle: "Navigate the commons",
});
const title = page ? entryTitle(page) : copy.homeMissingTitle;
const description = page ? entryDescription(page) : copy.homeMissingDescription;
const [featuredPost, ...remainingPosts] = posts;
const recentPosts = remainingPosts.slice(0, 3);
const navigationCards = [
  {
    description: copy.homeEssaysCardDescription,
    eyebrow: copy.homeEssaysCardEyebrow,
    href: "/blog/",
    mark: "01",
    title: copy.homeEssaysCardTitle,
    variant: "compact",
  },
  {
    description: copy.homeTopicsCardDescription,
    eyebrow: copy.homeTopicsCardEyebrow,
    href: "/topics/",
    mark: "02",
    title: copy.homeTopicsCardTitle,
    variant: "compact",
  },
  {
    description: copy.homePeopleCardDescription,
    eyebrow: copy.homePeopleCardEyebrow,
    href: "/people/",
    mark: "03",
    title: copy.homePeopleCardTitle,
    variant: "compact",
  },
] as const;
---

<SiteLayout title={title} description={description}>
  <div class="ds-homepage">
    <PageHero
      eyebrow={copy.homeHeroEyebrow}
      title={title}
      description={description}
    />

    {
      featuredPost && (
        <section class="ds-section" aria-labelledby="home-featured-heading">
          <header class="ds-section-header">
            <h2 class="ds-section-title" id="home-featured-heading">
              {copy.homeFeaturedHeading}
            </h2>
          </header>
          <div class="ds-card-grid ds-card-grid--content">
            <Card
              eyebrow={copy.homeFeaturedEyebrow}
              href={blogHref(featuredPost)}
              mark="01"
              meta={entryAuthorName(featuredPost) ?? undefined}
              description={entryDescription(featuredPost)}
              title={entryTitle(featuredPost)}
              variant="feature"
            />
            {recentPosts.slice(0, 1).map((post, index) => (
              <Card
                eyebrow={copy.articleCardEyebrow}
                href={blogHref(post)}
                mark={String(index + 2).padStart(2, "0")}
                meta={entryAuthorName(post) ?? undefined}
                description={entryDescription(post)}
                title={entryTitle(post)}
                variant="standard"
              />
            ))}
          </div>
        </section>
      )
    }

    {
      recentPosts.length > 1 && (
        <section class="ds-section" aria-labelledby="home-latest-heading">
          <header class="ds-section-header">
            <h2 class="ds-section-title" id="home-latest-heading">
              {copy.homeLatestHeading}
            </h2>
          </header>
          <div class="ds-card-grid ds-card-grid--latest">
            {recentPosts.slice(1).map((post, index) => (
              <Card
                eyebrow={copy.articleCardEyebrow}
                href={blogHref(post)}
                mark={String(index + 3).padStart(2, "0")}
                meta={entryAuthorName(post) ?? undefined}
                description={entryDescription(post)}
                title={entryTitle(post)}
                variant="standard"
              />
            ))}
          </div>
        </section>
      )
    }

    <section class="ds-section" aria-labelledby="home-navigation-heading">
      <header class="ds-section-header">
        <h2 class="ds-section-title" id="home-navigation-heading">
          {copy.homeNavigationHeading}
        </h2>
      </header>
      <div class="ds-card-grid ds-card-grid--routes">
        {
          navigationCards.map((card) => (
            <Card
              description={card.description}
              eyebrow={card.eyebrow}
              href={card.href}
              mark={card.mark}
              title={card.title}
              variant={card.variant}
            />
          ))
        }
      </div>
    </section>
  </div>
</SiteLayout>
