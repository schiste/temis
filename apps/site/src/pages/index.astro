---
import ArticleCard from "@temis/design-system/components/ArticleCard.astro";
import PageHero from "@temis/design-system/components/PageHero.astro";
import SiteLayout from "../components/SiteLayout.astro";
import {
  entryDescription,
  entrySlug,
  entryTitle,
  getHomePage,
  getPosts,
} from "../lib/emdash";
import { portableTextToHtml } from "../lib/portable-text";

const page = await getHomePage();
const posts = await getPosts();
const title = page ? entryTitle(page) : "TEMIS";
const description = page
  ? entryDescription(page)
  : "A static Astro site powered by EmDash content and Cloudflare.";
---

<SiteLayout title={title} description={description}>
  <PageHero
    eyebrow="Public map of a technical commons"
    title={title}
    description={description}
  />

  {
    page?.content && (
      <article class="ds-prose" set:html={portableTextToHtml(page.content)} />
    )
  }

  {
    posts.length > 0 && (
      <section class="ds-flow">
        <p class="ds-eyebrow">Latest</p>
        <div class="ds-listing">
          {posts.slice(0, 4).map((post) => (
            <ArticleCard
              href={`/blog/${entrySlug(post)}/`}
              title={entryTitle(post)}
              description={entryDescription(post)}
            />
          ))}
        </div>
      </section>
    )
  }
</SiteLayout>
