---
import ArticleCard from "@temis/design-system/components/ArticleCard.astro";
import PageHero from "@temis/design-system/components/PageHero.astro";
import SiteLayout from "../components/SiteLayout.astro";
import {
  entryAuthorName,
  entryDescription,
  entrySlug,
  entryTitle,
  getHomePage,
  getPosts,
  getSiteTexts,
} from "../lib/emdash";
import { portableTextToHtml } from "../lib/portable-text";

const page = await getHomePage();
const posts = await getPosts();
const copy = await getSiteTexts({
  articleCardEyebrow: "Article",
  homeHeroEyebrow: "Public map of a technical commons",
  homeLatestHeading: "Latest",
  homeMissingDescription:
    "A static Astro site powered by EmDash content and Cloudflare.",
  homeMissingTitle: "TEMIS",
});
const title = page ? entryTitle(page) : copy.homeMissingTitle;
const description = page ? entryDescription(page) : copy.homeMissingDescription;
---

<SiteLayout title={title} description={description}>
  <PageHero
    eyebrow={copy.homeHeroEyebrow}
    title={title}
    description={description}
  />

  {
    page?.content && (
      <article class="ds-prose" set:html={portableTextToHtml(page.content)} />
    )
  }

  {
    posts.length > 0 && (
      <section class="ds-flow">
        <p class="ds-eyebrow">{copy.homeLatestHeading}</p>
        <div class="ds-listing">
          {posts.slice(0, 4).map((post) => (
            <ArticleCard
              eyebrow={copy.articleCardEyebrow}
              href={`/blog/${entrySlug(post)}/`}
              title={entryTitle(post)}
              meta={entryAuthorName(post) ?? undefined}
              description={entryDescription(post)}
            />
          ))}
        </div>
      </section>
    )
  }
</SiteLayout>
