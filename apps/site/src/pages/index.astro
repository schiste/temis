---
import {
  entryDescription,
  entryTitle,
  getHomePage,
  getPosts,
} from "../lib/emdash";
import { portableTextToHtml } from "../lib/portable-text";
import "../styles/global.css";

const page = await getHomePage();
const posts = await getPosts();
const title = page ? entryTitle(page) : "TEMIS";
const description = page
  ? entryDescription(page)
  : "A static Astro site powered by EmDash content and Cloudflare.";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
  </head>
  <body>
    <main class="shell">
      <header class="site-header">
        <a class="brand" href="/">TEMIS</a>
        <nav class="nav" aria-label="Primary">
          <a href="/blog/">Blog</a>
        </nav>
      </header>

      <section class="hero">
        <p class="eyebrow">Static by default</p>
        <h1>{title}</h1>
        {description && <p class="lede">{description}</p>}
      </section>

      {
        page?.content && (
          <article
            class="content"
            set:html={portableTextToHtml(page.content)}
          />
        )
      }

      {
        posts.length > 0 && (
          <section>
            <h2>Latest</h2>
            <div class="listing">
              {posts.slice(0, 4).map((post) => (
                <a href={`/blog/${post.slug}/`}>
                  <strong>{entryTitle(post)}</strong>
                  {entryDescription(post) && (
                    <span>{entryDescription(post)}</span>
                  )}
                </a>
              ))}
            </div>
          </section>
        )
      }
    </main>
  </body>
</html>
