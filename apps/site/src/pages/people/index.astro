---
import Card from "@temis/design-system/components/Card.astro";
import PageHero from "@temis/design-system/components/PageHero.astro";
import RichContent from "@temis/design-system/components/RichContent.astro";
import SiteLayout from "../../components/SiteLayout.astro";
import {
  entryBylineBio,
  entryBylineHref,
  entryBylineName,
  entryDescription,
  entryTitle,
  getBylines,
  getPageBySlug,
  getSiteTexts,
} from "../../lib/emdash";

const page = await getPageBySlug("people");
const copy = await getSiteTexts({
  peopleCardEyebrow: "Author",
  peopleHeroEyebrow: "People",
  peopleMissingDescription:
    "Public people and author pages will provide context, trust, and authored work without becoming social profiles.",
  peopleMissingTitle: "People",
});
const bylines = await getBylines();
const title = page ? entryTitle(page) : copy.peopleMissingTitle;
const description = page
  ? entryDescription(page)
  : copy.peopleMissingDescription;
---

<SiteLayout title={title} description={description}>
  <PageHero
    eyebrow={copy.peopleHeroEyebrow}
    title={title}
    description={description}
  />

  {page?.content && <RichContent as="article" value={page.content} />}

  {
    bylines.length > 0 && (
      <div class="ds-card-grid">
        {bylines.map((byline) => (
          <Card
            variant="standard"
            eyebrow={copy.peopleCardEyebrow}
            href={entryBylineHref(byline)}
            title={entryBylineName(byline)}
            description={entryBylineBio(byline)}
          />
        ))}
      </div>
    )
  }
</SiteLayout>
