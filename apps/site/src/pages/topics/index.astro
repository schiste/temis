---
import GraphNavigation from "@temis/graph-navigation/components/GraphNavigation.astro";
import PageHero from "@temis/design-system/components/PageHero.astro";
import RichContent from "@temis/design-system/components/RichContent.astro";
import SiteLayout from "../../components/SiteLayout.astro";
import { getContentGraphSnapshot } from "../../lib/content-graph";
import {
  entryDescription,
  entryTitle,
  getPageBySlug,
  getSiteTexts,
} from "../../lib/emdash";

const page = await getPageBySlug("topics");
const graph = await getContentGraphSnapshot();
const copy = await getSiteTexts({
  topicsGraphHeading: "Content graph",
  topicsGraphLabel: "TEMIS content graph navigation",
  topicsHeroEyebrow: "Topics",
  topicsMissingDescription:
    "The TEMIS topic graph will make essays, tools, and people easier to explore as the V1 content model comes online.",
  topicsMissingTitle: "Topic map",
});
const title = page ? entryTitle(page) : copy.topicsMissingTitle;
const description = page
  ? entryDescription(page)
  : copy.topicsMissingDescription;
---

<SiteLayout title={title} description={description}>
  <PageHero
    eyebrow={copy.topicsHeroEyebrow}
    title={title}
    description={description}
  />

  {page?.content && <RichContent as="article" value={page.content} />}

  <section class="topics-graph" aria-label={copy.topicsGraphLabel}>
    <GraphNavigation
      graph={graph}
      defaultMode="overview"
      heading={copy.topicsGraphHeading}
      label={copy.topicsGraphLabel}
      showControls
      showLegend
    />
  </section>
</SiteLayout>

<style>
  .topics-graph {
    margin-block-start: var(--ds-space-phi-4);
  }
</style>
