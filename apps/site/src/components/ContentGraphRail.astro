---
import GraphNavigation from "@temis/graph-navigation/components/GraphNavigation.astro";
import type { GraphNavigationSnapshot } from "@temis/graph-navigation";

export interface Props {
  graph: GraphNavigationSnapshot;
  heading?: string;
  label?: string;
}

const {
  graph,
  heading = "Navigation graph",
  label = "Navigation graph from this page",
} = Astro.props;
---

{
  graph.nodes.length > 0 && (
    <section class="ds-content-graph" aria-label={label}>
      <GraphNavigation graph={graph} heading={heading} label={label} />
    </section>
  )
}
