  "collections": [
    {
      "slug": "pages",
      "label": "Pages",
      "labelSingular": "Page",
      "description": "Standalone static pages.",
      "icon": "file-text",
      "supports": ["drafts", "revisions", "preview", "seo", "search"],
      "urlPattern": "/{slug}",
      "fields": [
        {
          "slug": "title",
          "label": "Title",
          "type": "string",
          "required": true,
          "searchable": true
        },
        {
          "slug": "summary",
          "label": "Summary",
          "type": "text",
          "searchable": true
        },
        {
          "slug": "content",
          "label": "Content",
          "type": "portableText",
          "searchable": true
        },
        {
          "slug": "seo_title",
          "label": "SEO Title",
          "type": "string"
        },
        {
          "slug": "seo_description",
          "label": "SEO Description",
          "type": "text"
        }
      ]
    },
    {
      "slug": "posts",
      "label": "Posts",
      "labelSingular": "Post",
      "description": "Published articles.",
      "icon": "newspaper",
      "supports": [
        "drafts",
        "revisions",
        "preview",
        "seo",
        "search",
        "scheduling"
      ],
      "urlPattern": "/blog/{slug}",
      "fields": [
        {
          "slug": "title",
          "label": "Title",
          "type": "string",
          "required": true,
          "searchable": true
        },
        {
          "slug": "excerpt",
          "label": "Excerpt",
          "type": "text",
          "searchable": true
        },
        {
          "slug": "author_name",
          "label": "Author name",
          "type": "string",
          "searchable": true
        },
        {
          "slug": "featured_image",
          "label": "Featured Image",
          "type": "image"
        },
        {
          "slug": "content",
          "label": "Content",
          "type": "portableText",
          "searchable": true
        },
        {
          "slug": "seo_title",
          "label": "SEO Title",
          "type": "string"
        },
        {
          "slug": "seo_description",
          "label": "SEO Description",
          "type": "text"
        }
      ]
    },
    {
      "slug": "tools",
      "label": "Tools",
      "labelSingular": "Tool",
      "description": "First-class tools that connect articles, topics, tags, and people in the TEMIS graph.",
      "icon": "wrench",
      "supports": ["drafts", "revisions", "preview", "seo", "search"],
      "urlPattern": "/tools/{slug}",
      "fields": [
        {
          "slug": "title",
          "label": "Name",
          "type": "string",
          "required": true,
          "searchable": true
        },
        {
          "slug": "summary",
          "label": "Summary",
          "type": "text",
          "searchable": true
        },
        {
          "slug": "description",
          "label": "Description",
          "type": "portableText",
          "searchable": true
        },
        {
          "slug": "tool_url",
          "label": "Tool URL",
          "type": "url"
        },
        {
          "slug": "repository_url",
          "label": "Repository URL",
          "type": "url"
        },
        {
          "slug": "documentation_url",
          "label": "Documentation URL",
          "type": "url"
        },
        {
          "slug": "maturity",
          "label": "Maturity",
          "type": "select",
          "validation": {
            "options": ["prototype", "active", "stable", "archived"]
          }
        },
        {
          "slug": "featured_image",
          "label": "Featured Image",
          "type": "image"
        },
        {
          "slug": "related_articles",
          "label": "Related Articles",
          "type": "reference",
          "options": {
            "collection": "posts",
            "allowMultiple": true
          }
        },
        {
          "slug": "graph_visible",
          "label": "Visible in Graph",
          "type": "boolean",
          "defaultValue": true
        },
        {
          "slug": "graph_priority",
          "label": "Graph Priority",
          "type": "number"
        },
        {
          "slug": "seo_title",
          "label": "SEO Title",
          "type": "string"
        },
        {
          "slug": "seo_description",
          "label": "SEO Description",
          "type": "text"
        }
      ]
    }
  ],
  "taxonomies": [
    {
      "name": "category",
      "label": "Categories",
      "labelSingular": "Category",
      "hierarchical": true,
      "collections": ["posts", "tools"]
    },
    {
      "name": "tag",
      "label": "Tags",
      "labelSingular": "Tag",
      "hierarchical": false,
      "collections": ["posts", "tools"]
    }
  ],
