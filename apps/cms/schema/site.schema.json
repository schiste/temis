      "slug": "lodewijk-gelauff",
      "displayName": "Lodewijk Gelauff",
      "bio": "Lodewijk Gelauff is a computational social scientist working on democratic innovation. He explores Wikimedia governance, dseliberation, and community decision-making tools."
    },
    {
      "slug": "christophe-henner",
      "displayName": "Christophe Henner",
      "bio": "Christophe Henner is a 20-year Wikimedian, former Chair of Wikimedia France, and former Chair of the Wikimedia Foundation Board of Trustees."
    }
  ],
