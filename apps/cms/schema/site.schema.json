  "contentDefaults": [
    {
      "collection": "pages",
      "slug": "search",
      "fields": {
        "title": "Search",
        "summary": "Search the published TEMIS static snapshot across essays, tools, publications, people, and pages.",
        "content": [
          {
            "_type": "block",
            "style": "normal",
            "children": [
              {
                "_type": "span",
                "text": "This local search index is generated at build time from published EmDash content: essays, tools, publications, people, and pages."
              }
            ]
          }
        ]
      }
    },
    {
      "collection": "pages",
      "slug": "tools",
      "fields": {
        "title": "Tool index",
        "summary": "Software, prototypes, and research pipelines connected to open knowledge work.",
        "content": [
          {
            "_type": "block",
            "style": "normal",
            "children": [
              {
                "_type": "span",
                "text": "Tools are first-class TEMIS records: they connect authors, articles, repositories, topics, and maintenance signals into the graph."
              }
            ]
          }
        ]
      }
    },
    {
      "collection": "pages",
      "slug": "publications",
      "fields": {
        "title": "Publication index",
        "summary": "Research papers, reports, and other publications connected to TEMIS essays, tools, people, and topics.",
        "content": [
          {
            "_type": "block",
            "style": "normal",
            "children": [
              {
                "_type": "span",
                "text": "Publications are first-class knowledge objects in TEMIS. Editorial posts may summarize or discuss them, tools may implement them, and the graph can connect them to people and topics without treating them as ordinary articles."
              }
            ]
          }
        ]
      }
    },
    {
