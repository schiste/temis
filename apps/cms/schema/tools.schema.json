{
  "version": 1,
  "collections": [
    {
      "slug": "tools",
      "table": "ec_tools",
      "label": "Tools",
      "labelSingular": "Tool",
      "description": "First-class tools that connect articles, topics, tags, and people in the TEMIS graph.",
      "icon": "wrench",
      "supports": ["drafts", "revisions", "preview", "seo", "search"],
      "urlPattern": "/tools/{slug}",
      "fields": [
        {
          "slug": "title",
          "label": "Name",
          "type": "string",
          "columnType": "TEXT",
          "required": true,
          "searchable": true
        },
        {
          "slug": "summary",
          "label": "Summary",
          "type": "text",
          "columnType": "TEXT",
          "searchable": true
        },
        {
          "slug": "description",
          "label": "Description",
          "type": "portableText",
          "columnType": "JSON",
          "searchable": true
        },
        {
          "slug": "tool_url",
          "label": "Tool URL",
          "type": "url",
          "columnType": "TEXT"
        },
        {
          "slug": "repository_url",
          "label": "Repository URL",
          "type": "url",
          "columnType": "TEXT"
        },
        {
          "slug": "documentation_url",
          "label": "Documentation URL",
          "type": "url",
          "columnType": "TEXT"
        },
        {
          "slug": "license",
          "label": "License",
          "type": "string",
          "columnType": "TEXT",
          "required": true,
          "searchable": true
        },
        {
          "slug": "privacy_note",
          "label": "Privacy note",
          "type": "text",
          "columnType": "TEXT",
          "required": true,
          "searchable": true
        },
        {
          "slug": "technical_maturity",
          "label": "Technical maturity",
          "type": "select",
          "columnType": "TEXT",
          "required": true,
          "validation": {
            "options": [
              "prototype",
              "experimental",
              "active",
              "stable",
              "archived"
            ]
          }
        },
        {
          "slug": "editorial_confidence",
          "label": "Editorial confidence",
          "type": "select",
          "columnType": "TEXT",
          "required": true,
          "validation": {
            "options": [
              "observed",
              "promising",
              "used_by_temis",
              "recommended",
              "needs_review"
            ]
          }
        },
        {
          "slug": "featured_image",
          "label": "Featured Image",
          "type": "image",
          "columnType": "TEXT"
        },
        {
          "slug": "screenshot_url",
          "label": "Screenshot URL",
          "type": "url",
          "columnType": "TEXT"
        },
        {
          "slug": "screenshot_alt",
          "label": "Screenshot alt text",
          "type": "text",
          "columnType": "TEXT"
        },
        {
          "slug": "screenshot_caption",
          "label": "Screenshot caption",
          "type": "text",
          "columnType": "TEXT"
        },
        {
          "slug": "screenshot_license",
          "label": "Screenshot license",
          "type": "string",
          "columnType": "TEXT"
        },
        {
          "slug": "related_articles",
          "label": "Related Articles",
          "type": "reference",
          "columnType": "TEXT",
          "options": {
            "collection": "posts",
            "allowMultiple": true
          }
        },
        {
          "slug": "related_people",
          "label": "Related people and roles",
          "type": "text",
          "columnType": "TEXT"
        },
        {
          "slug": "graph_visible",
          "label": "Visible in Graph",
          "type": "boolean",
          "columnType": "INTEGER",
          "defaultValue": true
        },
        {
          "slug": "graph_priority",
          "label": "Graph Priority",
          "type": "number",
          "columnType": "REAL"
        },
        {
          "slug": "seo_title",
          "label": "SEO Title",
          "type": "string",
          "columnType": "TEXT"
        },
        {
          "slug": "seo_description",
          "label": "SEO Description",
          "type": "text",
          "columnType": "TEXT"
        }
      ]
    }
  ]
}
