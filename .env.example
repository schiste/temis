# Public static site
TEMIS_PUBLIC_SITE_URL=https://temis.pages.dev

# CMS / preview worker
TEMIS_CMS_SITE_URL=https://temis-cms.workers.dev
EMDASH_PREVIEW_SECRET=replace-with-a-long-random-secret
TEMIS_INITIAL_ADMIN_EMAIL=christophe.henner@gmail.com

# Cloudflare Pages deploy hook, created in the Cloudflare Pages dashboard.
# The EmDash deploy plugin calls this after publish/unpublish events.
TEMIS_PAGES_DEPLOY_HOOK_URL=https://api.cloudflare.com/client/v4/pages/webhooks/deploy_hooks/replace-me

# Tool pipeline Worker
# Set these on the temis-tool-pipeline Worker with wrangler secret put.
# The Worker can reuse TEMIS_PAGES_DEPLOY_HOOK_URL from above as a secret.
TEMIS_TOOL_PIPELINE_TOKEN=replace-with-a-long-random-manual-run-token
TEMIS_GITHUB_TOKEN=github_pat_or_fine_grained_token_optional
