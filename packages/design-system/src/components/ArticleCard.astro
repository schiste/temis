---
export interface Props {
  description?: string;
  eyebrow?: string;
  href: string;
  title: string;
}

const { description, eyebrow = "Article", href, title } = Astro.props;
---

<a class="ds-article-card" href={href}>
  <span class="ds-article-card__eyebrow">{eyebrow}</span>
  <strong class="ds-article-card__title">{title}</strong>
  {
    description && (
      <span class="ds-article-card__description">{description}</span>
    )
  }
</a>
