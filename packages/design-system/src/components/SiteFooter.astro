---
export interface Props {
  commonsHeading?: string;
  commonsText?: string;
  footerAriaLabel?: string;
  licenseAriaLabel?: string;
  licenseHeading?: string;
  licenseLabel?: string;
  licensePrefix?: string;
  licenseUrl?: string;
  openHeading?: string;
  openText?: string;
  siteHeading?: string;
  siteText?: string;
  topAriaLabel?: string;
  topLabel?: string;
}

const {
  commonsHeading = "Built for the commons",
  commonsText = "TEMIS is a public resource. Contribute, share, improve.",
  footerAriaLabel = "Site footer",
  licenseAriaLabel,
  licenseHeading = "License",
  licenseLabel = "CC BY-SA 4.0",
  licensePrefix = "Content on TEMIS is licensed under",
  licenseUrl = "https://creativecommons.org/licenses/by-sa/4.0/",
  openHeading = "Open by default",
  openText = "No tracking. No profiling. Just public knowledge.",
  siteHeading = "TEMIS",
  siteText = "A working group exploring the future of open knowledge.",
  topAriaLabel = "Back to top",
  topLabel = "Top",
} = Astro.props;
const resolvedLicenseAriaLabel = licenseAriaLabel ?? `${licenseLabel} license`;
---

<footer class="ds-site-footer" aria-label={footerAriaLabel}>
  <section class="ds-footer-cell ds-footer-cell--open">
    <div>
      <p class="ds-footer-heading">{openHeading}</p>
      <p>{openText}</p>
    </div>
    <span class="ds-footer-open-mark" aria-hidden="true">+</span>
  </section>

  <section class="ds-footer-cell ds-footer-cell--license">
    <div>
      <p class="ds-footer-heading">{licenseHeading}</p>
      <p>
        {licensePrefix}
        <a href={licenseUrl} rel="license">{licenseLabel}</a>.
      </p>
    </div>
    <a
      class="ds-footer-license-mark"
      href={licenseUrl}
      rel="license"
      aria-label={resolvedLicenseAriaLabel}>CC</a
    >
  </section>

  <section class="ds-footer-cell ds-footer-cell--commons">
    <div>
      <p class="ds-footer-heading">{commonsHeading}</p>
      <p>{commonsText}</p>
    </div>
    <svg
      class="ds-footer-corners"
      viewBox="0 0 26 26"
      role="img"
      aria-label="Commons frame mark"
    >
      <path d="M2 8V2h6M18 2h6v6M24 18v6h-6M8 24H2v-6"></path>
    </svg>
  </section>

  <section class="ds-footer-cell ds-footer-cell--temis">
    <p class="ds-footer-heading">{siteHeading}</p>
    <p>{siteText}</p>
  </section>

  <a class="ds-footer-top" href="#top" aria-label={topAriaLabel}>
    <svg viewBox="0 0 18 18" aria-hidden="true">
      <path d="M9 15V3M4 8l5-5 5 5"></path>
    </svg>
    <span>{topLabel}</span>
  </a>
</footer>
