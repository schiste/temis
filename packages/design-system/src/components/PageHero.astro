---
export interface Props {
  eyebrow?: string;
  ledeSize?: "default" | "small";
  title: string;
  description?: string;
}

const { description, eyebrow, ledeSize = "default", title } = Astro.props;
const ledeClassName = `ds-lede${ledeSize === "small" ? " ds-lede--small" : ""}`;
---

<section class="ds-page-hero">
  {eyebrow && <p class="ds-eyebrow">{eyebrow}</p>}
  <h1 class="ds-page-title">{title}</h1>
  {description && <p class={ledeClassName}>{description}</p>}
</section>
