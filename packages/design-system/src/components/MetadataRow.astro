---
export interface MetadataItem {
  href?: string;
  label?: string;
  value: string;
}

export interface Props {
  items: MetadataItem[];
}

const { items } = Astro.props;
---

{
  items.length > 0 && (
    <dl class="ds-meta-row">
      {items.map((item) => (
        <div>
          {item.label && <dt class="ds-visually-hidden">{item.label}</dt>}
          <dd>
            {item.href ? <a href={item.href}>{item.value}</a> : item.value}
          </dd>
        </div>
      ))}
    </dl>
  )
}
