---
import { withGraphNavigationLayout } from "../layout";
import type {
  GraphNavigationNode,
  GraphNavigationNodeType,
  GraphNavigationSnapshot,
} from "../types";

export interface Props {
  graph: GraphNavigationSnapshot;
  heading?: string;
  label?: string;
  variant?: "default" | "compact";
}

const {
  graph,
  heading = "Content graph",
  label = "Content graph navigation",
  variant = "default",
} = Astro.props;
const showNodeMeta = variant !== "compact";
const nodeTypeLabels: Record<GraphNavigationNodeType, string> = {
  author: "Author",
  content: "Content",
  tag: "Tag",
  tool: "Tool",
  topic: "Topic",
};
const nodeTypeShortLabels: Record<GraphNavigationNodeType, string> = {
  author: "A",
  content: "C",
  tag: "#",
  tool: "T",
  topic: "+",
};
const laidOutGraph = withGraphNavigationLayout(graph);
type VisualGraphNode = GraphNavigationNode & {
  idleDelay: number;
  idleDuration: number;
  idleX: number;
  idleY: number;
  visualX: number;
  visualY: number;
};
type VisualGraphEdge = (typeof laidOutGraph.edges)[number] & {
  path: string;
  sourceNode: VisualGraphNode;
  targetNode: VisualGraphNode;
};

function hashText(value: string) {
  let hash = 2166136261;

  for (let index = 0; index < value.length; index += 1) {
    hash ^= value.charCodeAt(index);
    hash = Math.imul(hash, 16777619);
  }

  return hash >>> 0;
}

function round(value: number) {
  return Math.round(value * 100) / 100;
}

function clamp(value: number, min: number, max: number) {
  return Math.min(max, Math.max(min, value));
}

function seededUnit(id: string, salt: string) {
  return hashText(`${id}:${salt}`) / 0xffffffff;
}

function seededSignedUnit(id: string, salt: string) {
  return seededUnit(id, salt) * 2 - 1;
}

function toVisualNode(node: GraphNavigationNode): VisualGraphNode {
  const baseX = node.x ?? 50;
  const baseY = node.y ?? 50;
  const visualX = round(
    clamp(baseX + seededSignedUnit(node.id, "constellation-x") * 2.35, 8, 92),
  );
  const visualY = round(
    clamp(baseY + seededSignedUnit(node.id, "constellation-y") * 2.1, 8, 92),
  );

  return {
    ...node,
    idleDelay: -Math.round(seededUnit(node.id, "idle-delay") * 9000),
    idleDuration:
      8800 + Math.round(seededUnit(node.id, "idle-duration") * 4200),
    idleX: round(seededSignedUnit(node.id, "idle-x") * 0.12),
    idleY: round(seededSignedUnit(node.id, "idle-y") * 0.12),
    visualX,
    visualY,
  };
}

function edgePath(
  edgeId: string,
  sourceNode: VisualGraphNode,
  targetNode: VisualGraphNode,
) {
  const x1 = sourceNode.visualX;
  const y1 = sourceNode.visualY;
  const x2 = targetNode.visualX;
  const y2 = targetNode.visualY;
  const dx = x2 - x1;
  const dy = y2 - y1;
  const distance = Math.hypot(dx, dy) || 1;
  const normalX = -dy / distance;
  const normalY = dx / distance;
  const direction = seededSignedUnit(edgeId, "curve-side") >= 0 ? 1 : -1;
  const bend =
    Math.min(5.2, Math.max(1.8, distance * 0.08)) *
    direction *
    (0.78 + seededUnit(edgeId, "curve-weight") * 0.44);
  const controlX = round((x1 + x2) / 2 + normalX * bend);
  const controlY = round((y1 + y2) / 2 + normalY * bend);

  return `M ${round(x1)} ${round(y1)} Q ${controlX} ${controlY} ${round(
    x2,
  )} ${round(y2)}`;
}

const visualNodes = laidOutGraph.nodes.map(toVisualNode);
const nodesById = new Map(visualNodes.map((node) => [node.id, node]));
const edges: VisualGraphEdge[] = laidOutGraph.edges
  .map((edge): VisualGraphEdge | null => {
    const sourceNode = nodesById.get(edge.source);
    const targetNode = nodesById.get(edge.target);
    if (!sourceNode || !targetNode) return null;

    return {
      ...edge,
      path: edgePath(edge.id, sourceNode, targetNode),
      sourceNode,
      targetNode,
    };
  })
  .filter((edge): edge is VisualGraphEdge => edge !== null);
const relatedNodesById = new Map<string, typeof visualNodes>();

for (const edge of edges) {
  if (!edge.sourceNode || !edge.targetNode) continue;

  relatedNodesById.set(edge.source, [
    ...(relatedNodesById.get(edge.source) ?? []),
    edge.targetNode,
  ]);
  relatedNodesById.set(edge.target, [
    ...(relatedNodesById.get(edge.target) ?? []),
    edge.sourceNode,
  ]);
}

const initialDetailNodeId =
  laidOutGraph.currentNodeId && nodesById.has(laidOutGraph.currentNodeId)
    ? laidOutGraph.currentNodeId
    : visualNodes[0]?.id;
const detailPanels = visualNodes.map((node) => ({
  node,
  relatedNodes: [...(relatedNodesById.get(node.id) ?? [])].sort((a, b) => {
    if (a.priority !== b.priority) return b.priority - a.priority;
    return a.label.localeCompare(b.label);
  }),
}));
const detailRegionId = `temis-graph-details-${hashText(`${heading}:${label}:${laidOutGraph.generatedAt}`)}`;
---

<nav
  class:list={[
    "temis-graph-nav",
    variant === "compact" && "temis-graph-nav--compact",
  ]}
  aria-label={label}
>
  <div class="temis-graph-nav__header">
    <h2>{heading}</h2>
    <span>{laidOutGraph.scope}</span>
  </div>

  <div class="temis-graph-nav__map">
    <svg
      class="temis-graph-nav__edges"
      viewBox="0 0 100 100"
      preserveAspectRatio="none"
      aria-hidden="true"
    >
      {
        edges.map((edge) => (
          <path
            d={edge.path}
            data-edge-source={edge.source}
            data-edge-target={edge.target}
          />
        ))
      }
    </svg>

    {
      visualNodes.map((node) => (
        <a
          class:list={[
            "temis-graph-nav__node",
            `temis-graph-nav__node--${node.type}`,
            node.id === laidOutGraph.currentNodeId &&
              "temis-graph-nav__node--current",
          ]}
          aria-label={`${node.label} (${nodeTypeLabels[node.type]})`}
          aria-controls={detailRegionId}
          aria-expanded={node.id === initialDetailNodeId ? "true" : "false"}
          data-node-id={node.id}
          data-node-type={node.type}
          href={node.href}
          id={`graph-node-${node.slug}`}
          style={`--node-x:${node.visualX};--node-y:${node.visualY};--node-idle-x:${node.idleX}rem;--node-idle-y:${node.idleY}rem;--node-idle-duration:${node.idleDuration}ms;--node-idle-delay:${node.idleDelay}ms;${node.accent ? `--node-accent:${node.accent};` : ""}`}
        >
          {variant === "compact" && (
            <span class="temis-graph-nav__node-marker" aria-hidden="true">
              {nodeTypeShortLabels[node.type]}
            </span>
          )}
          <span class="temis-graph-nav__node-label">{node.label}</span>
        </a>
      ))
    }
  </div>

  {
    variant === "compact" && visualNodes.length > 1 && (
      <div class="temis-graph-nav__index" aria-label="Graph nodes">
        {visualNodes.map((node) => (
          <a
            class:list={[
              "temis-graph-nav__index-link",
              node.id === laidOutGraph.currentNodeId &&
                "temis-graph-nav__index-link--current",
            ]}
            aria-controls={detailRegionId}
            aria-expanded={node.id === initialDetailNodeId ? "true" : "false"}
            data-index-node-id={node.id}
            href={node.href}
          >
            <span aria-hidden="true">{nodeTypeShortLabels[node.type]}</span>
            <strong>{node.label}</strong>
            <em>{nodeTypeLabels[node.type]}</em>
          </a>
        ))}
      </div>
    )
  }

  <section
    class="temis-graph-nav__details"
    aria-label="Selected graph node"
    aria-live="polite"
    id={detailRegionId}
  >
    {
      detailPanels.map(({ node, relatedNodes }) => (
        <article
          class="temis-graph-nav__detail"
          data-detail-node-id={node.id}
          hidden={node.id !== initialDetailNodeId}
        >
          <div class="temis-graph-nav__detail-main">
            <p class="temis-graph-nav__detail-type">
              {nodeTypeLabels[node.type]}
            </p>
            <h3>{node.label}</h3>
            {node.description && <p>{node.description}</p>}
            {showNodeMeta && node.meta.length > 0 && (
              <dl class="temis-graph-nav__detail-meta">
                {node.meta.map((item) => (
                  <div>
                    <dt>{item.label}</dt>
                    <dd>
                      {item.href ? (
                        <a href={item.href}>{item.value}</a>
                      ) : item.datetime ? (
                        <time datetime={item.datetime}>{item.value}</time>
                      ) : (
                        item.value
                      )}
                    </dd>
                  </div>
                ))}
              </dl>
            )}
          </div>

          <div class="temis-graph-nav__detail-actions">
            <a href={node.href} aria-label={`Open ${node.label}`}>
              Open
            </a>
          </div>

          {relatedNodes.length > 0 && (
            <div class="temis-graph-nav__detail-related">
              <p>Related</p>
              <ul>
                {relatedNodes.map((relatedNode) => (
                  <li>
                    <a href={relatedNode.href}>{relatedNode.label}</a>
                    <span>{nodeTypeLabels[relatedNode.type]}</span>
                  </li>
                ))}
              </ul>
            </div>
          )}
        </article>
      ))
    }
  </section>

  <ul class="temis-graph-nav__fallback">
    {
      visualNodes.map((node) => (
        <li>
          <div class="temis-graph-nav__fallback-head">
            <a href={node.href}>{node.label}</a>
            <span>{nodeTypeLabels[node.type]}</span>
          </div>
          {node.description && (
            <span class="temis-graph-nav__fallback-description">
              {node.description}
            </span>
          )}
        </li>
      ))
    }
  </ul>
</nav>

<style>
  .temis-graph-nav {
    --temis-graph-link-active: color-mix(
      in srgb,
      #00a66a 88%,
      var(--ds-color-text, currentColor) 12%
    );
    box-shadow:
      inset 0 var(--ds-stroke-hairline, 1px) 0
        var(--ds-color-line-strong, currentColor),
      inset 0 calc(var(--ds-stroke-hairline, 1px) * -1) 0
        var(--ds-color-line-strong, currentColor);
    color: var(--ds-color-text, currentColor);
    display: grid;
    gap: 0;
    padding-block: 0;
  }

  .temis-graph-nav__header {
    align-items: center;
    display: flex;
    font-family: var(--ds-font-mono, ui-monospace);
    justify-content: space-between;
    min-height: var(--ds-row-unit, var(--ds-grid-unit, 2.625rem));
    text-transform: uppercase;
  }

  .temis-graph-nav__header h2,
  .temis-graph-nav__header span {
    font-size: var(--ds-font-size-meta, 0.75rem);
    line-height: 1;
    margin: 0;
  }

  .temis-graph-nav__header span {
    color: var(--ds-color-text-muted, currentColor);
  }

  .temis-graph-nav__map {
    aspect-ratio: 2.618 / 1;
    background:
      linear-gradient(
        90deg,
        color-mix(in srgb, var(--ds-color-line, currentColor) 36%, transparent)
          var(--ds-stroke-hairline, 1px),
        transparent var(--ds-stroke-hairline, 1px)
      ),
      color-mix(in srgb, var(--ds-color-panel, transparent) 50%, transparent);
    background-size: var(--ds-grid-unit, 2.625rem)
      var(--ds-row-unit, var(--ds-grid-unit, 2.625rem));
    min-height: calc(var(--ds-row-unit, var(--ds-grid-unit, 2.625rem)) * 8);
    position: relative;
  }

  .temis-graph-nav__edges {
    height: 100%;
    inset: 0;
    position: absolute;
    width: 100%;
  }

  .temis-graph-nav__edges path {
    fill: none;
    stroke: var(--ds-color-line-strong, currentColor);
    stroke-linecap: square;
    stroke-width: 0.44px;
    opacity: 0.82;
    transform-box: fill-box;
    transform-origin: center;
    transition:
      opacity 160ms ease,
      stroke-width 160ms ease,
      transform 160ms ease;
    vector-effect: non-scaling-stroke;
  }

  .temis-graph-nav__node {
    --node-accent: var(--ds-color-accent, currentColor);
    align-items: center;
    background: var(--ds-color-surface, Canvas);
    border: var(--ds-stroke-hairline, 1px) solid var(--node-accent);
    color: var(--ds-color-text, currentColor);
    display: inline-flex;
    font-family: var(--ds-font-mono, ui-monospace);
    font-size: var(--ds-font-size-meta, 0.75rem);
    font-weight: 700;
    inset-block-start: calc(var(--node-y) * 1%);
    inset-inline-start: calc(var(--node-x) * 1%);
    line-height: 1.1;
    max-width: calc(var(--ds-grid-unit, 2.625rem) * 5);
    min-height: var(--ds-row-unit, var(--ds-grid-unit, 2.625rem));
    padding: var(--ds-space-phi-1, 0.625rem);
    position: absolute;
    text-decoration: none;
    text-transform: uppercase;
    transition:
      background-color 160ms ease,
      border-color 160ms ease,
      color 160ms ease,
      opacity 160ms ease,
      transform 160ms ease;
    transform: translate(-50%, -50%);
  }

  .temis-graph-nav__node-label {
    display: inline-block;
    transition: transform 160ms ease;
  }

  .temis-graph-nav__node-marker {
    display: none;
  }

  .temis-graph-nav__node--content {
    --node-accent: var(--ds-color-accent, currentColor);
  }

  .temis-graph-nav__node--topic {
    --node-accent: var(--ds-color-accent, currentColor);
  }

  .temis-graph-nav__node--tag {
    --node-accent: var(--ds-color-text-muted, currentColor);
  }

  .temis-graph-nav__node--author {
    --node-accent: var(--ds-color-line-strong, currentColor);
  }

  .temis-graph-nav__node--tool {
    --node-accent: var(--ds-color-focus, var(--ds-color-accent, currentColor));
  }

  .temis-graph-nav__node:hover,
  .temis-graph-nav__node:focus-visible,
  .temis-graph-nav__node[data-graph-state="active"],
  .temis-graph-nav__node--current {
    background: var(--node-accent);
    color: var(--ds-color-accent-contrast, Canvas);
  }

  .temis-graph-nav__node[data-graph-state="neighbor"] {
    border-color: var(--node-accent);
    color: var(--node-accent);
    opacity: 1;
  }

  .temis-graph-nav[data-graph-active] .temis-graph-nav__node {
    opacity: 0.22;
  }

  .temis-graph-nav[data-graph-active]
    .temis-graph-nav__node[data-graph-state="active"],
  .temis-graph-nav[data-graph-active]
    .temis-graph-nav__node[data-graph-state="neighbor"] {
    opacity: 1;
  }

  .temis-graph-nav[data-graph-active] .temis-graph-nav__edges path {
    opacity: 0.08;
  }

  .temis-graph-nav[data-graph-active]
    .temis-graph-nav__edges
    path[data-graph-state="related"] {
    opacity: 0.98;
    stroke: var(--temis-graph-link-active);
    stroke-width: 0.74px;
    transform: scale(1.006);
  }

  .temis-graph-nav__details {
    box-shadow: inset 0 var(--ds-stroke-hairline, 1px) 0
      var(--ds-color-line-strong, currentColor);
    scroll-margin-block-start: var(
      --ds-row-unit,
      var(--ds-space-phi-3, 1.625rem)
    );
    transition:
      border-color 160ms ease,
      box-shadow 160ms ease;
  }

  .temis-graph-nav[data-graph-locked] .temis-graph-nav__details {
    box-shadow: inset 0 var(--ds-stroke-hairline, 1px) 0
      var(--temis-graph-link-active);
  }

  .temis-graph-nav__detail {
    border-block-end: var(--ds-stroke-hairline, 1px) solid
      var(--ds-color-line, currentColor);
    display: grid;
    gap: var(--ds-row-half, var(--ds-space-phi-2, 1rem));
    grid-template-columns: minmax(0, 1fr) auto;
    min-height: calc(var(--ds-row-unit, var(--ds-grid-unit, 2.625rem)) * 2);
    padding-block: var(--ds-row-half, var(--ds-space-phi-2, 1rem));
  }

  .temis-graph-nav__detail[hidden] {
    display: none;
  }

  .temis-graph-nav__detail-main {
    display: grid;
    gap: var(--ds-space-phi-00, 0.25rem);
  }

  .temis-graph-nav__detail-type,
  .temis-graph-nav__detail-related > p {
    color: var(--ds-color-text-muted, currentColor);
    font-family: var(--ds-font-mono, ui-monospace);
    font-size: var(--ds-font-size-caption, 0.625rem);
    line-height: 1;
    margin: 0;
    text-transform: uppercase;
  }

  .temis-graph-nav__detail h3 {
    font-size: var(--ds-font-size-title-sm, 1.625rem);
    line-height: var(--ds-line-tight, 1.1);
    margin: 0;
  }

  .temis-graph-nav__detail-main > p:not(.temis-graph-nav__detail-type) {
    color: var(--ds-color-text-muted, currentColor);
    font-size: var(--ds-font-size-body, 1rem);
    margin: 0;
    max-width: var(
      --ds-measure-prose,
      calc(var(--ds-grid-unit, 2.625rem) * 16)
    );
  }

  .temis-graph-nav__detail-meta {
    border-block-start: var(--ds-stroke-hairline, 1px) solid
      var(--ds-color-line, currentColor);
    display: grid;
    gap: 0;
    grid-template-columns: repeat(
      auto-fit,
      minmax(calc(var(--ds-grid-unit, 2.625rem) * 4), 1fr)
    );
    margin: var(--ds-row-quarter, var(--ds-space-phi-1, 0.625rem)) 0 0;
  }

  .temis-graph-nav__detail-meta div {
    border-block-end: var(--ds-stroke-hairline, 1px) solid
      var(--ds-color-line, currentColor);
    display: grid;
    gap: var(--ds-space-phi-00, 0.25rem);
    min-height: var(--ds-row-unit, var(--ds-grid-unit, 2.625rem));
    padding-block: var(--ds-row-quarter, var(--ds-space-phi-1, 0.625rem));
  }

  .temis-graph-nav__detail-meta dt,
  .temis-graph-nav__detail-meta dd {
    margin: 0;
  }

  .temis-graph-nav__detail-meta dt {
    color: var(--ds-color-text-muted, currentColor);
    font-family: var(--ds-font-mono, ui-monospace);
    font-size: var(--ds-font-size-caption, 0.625rem);
    line-height: 1;
    text-transform: uppercase;
  }

  .temis-graph-nav__detail-meta dd {
    font-family: var(--ds-font-mono, ui-monospace);
    font-size: var(--ds-font-size-meta, 0.75rem);
    font-weight: 700;
    line-height: 1.2;
    overflow-wrap: anywhere;
  }

  .temis-graph-nav__detail-meta a {
    color: var(--temis-graph-link-active);
  }

  .temis-graph-nav__detail-actions a {
    align-items: center;
    border: var(--ds-stroke-hairline, 1px) solid
      var(--ds-color-line-strong, currentColor);
    color: var(--ds-color-text, currentColor);
    display: inline-flex;
    font-family: var(--ds-font-mono, ui-monospace);
    font-size: var(--ds-font-size-meta, 0.75rem);
    font-weight: 700;
    min-height: var(--ds-row-unit, var(--ds-grid-unit, 2.625rem));
    padding-inline: var(--ds-space-phi-1, 0.625rem);
    text-decoration: none;
    text-transform: uppercase;
  }

  .temis-graph-nav__detail-actions a:hover,
  .temis-graph-nav__detail-actions a:focus-visible {
    background: var(--ds-color-text, currentColor);
    color: var(--ds-color-surface, Canvas);
  }

  .temis-graph-nav__detail-related {
    display: grid;
    gap: var(--ds-space-phi-1, 0.625rem);
    grid-column: 1 / -1;
  }

  .temis-graph-nav__detail-related ul {
    display: grid;
    gap: 0;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .temis-graph-nav__detail-related li {
    align-items: baseline;
    border-block-start: var(--ds-stroke-hairline, 1px) solid
      var(--ds-color-line, currentColor);
    display: grid;
    gap: var(--ds-space-phi-1, 0.625rem);
    grid-template-columns: minmax(0, 1fr) auto;
    min-height: var(--ds-row-unit, var(--ds-grid-unit, 2.625rem));
    padding-block: var(--ds-row-quarter, var(--ds-space-phi-1, 0.625rem));
  }

  .temis-graph-nav__detail-related a {
    color: var(--temis-graph-link-active);
    font-family: var(--ds-font-mono, ui-monospace);
    font-size: var(--ds-font-size-meta, 0.75rem);
    text-transform: uppercase;
  }

  .temis-graph-nav__detail-related span {
    color: var(--ds-color-text-muted, currentColor);
    font-family: var(--ds-font-mono, ui-monospace);
    font-size: var(--ds-font-size-caption, 0.625rem);
    text-transform: uppercase;
  }

  .temis-graph-nav__index {
    display: none;
  }

  .temis-graph-nav__fallback {
    border-block-start: var(--ds-stroke-hairline, 1px) solid
      var(--ds-color-line, currentColor);
    display: none;
    gap: 0;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .temis-graph-nav__fallback li {
    border-block-end: var(--ds-stroke-hairline, 1px) solid
      var(--ds-color-line, currentColor);
    display: grid;
    gap: var(--ds-space-phi-00, 0.25rem);
    min-height: var(--ds-row-unit, var(--ds-grid-unit, 2.625rem));
    padding-block: var(--ds-row-quarter, var(--ds-space-phi-1, 0.625rem));
  }

  .temis-graph-nav__fallback-head {
    align-items: baseline;
    display: flex;
    gap: var(--ds-space-phi-1, 0.625rem);
    justify-content: space-between;
  }

  .temis-graph-nav__fallback a {
    font-family: var(--ds-font-mono, ui-monospace);
    font-size: var(--ds-font-size-meta, 0.75rem);
    text-transform: uppercase;
  }

  .temis-graph-nav__fallback-head span {
    color: var(--ds-color-text-muted, currentColor);
    font-family: var(--ds-font-mono, ui-monospace);
    font-size: var(--ds-font-size-caption, 0.625rem);
    text-transform: uppercase;
  }

  .temis-graph-nav__fallback-description {
    color: var(--ds-color-text-muted, currentColor);
    font-size: var(--ds-font-size-body, 1rem);
  }

  .temis-graph-nav--compact {
    gap: var(--ds-space-phi-1, 0.625rem);
    padding-block: var(--ds-space-phi-1, 0.625rem);
  }

  .temis-graph-nav--compact .temis-graph-nav__map {
    aspect-ratio: 1 / 1;
    min-height: calc(var(--ds-row-unit, var(--ds-grid-unit, 2.625rem)) * 6);
    overflow: hidden;
  }

  .temis-graph-nav--compact .temis-graph-nav__node {
    block-size: var(--ds-space-phi-2, 1rem);
    inline-size: var(--ds-space-phi-2, 1rem);
    justify-content: center;
    max-width: none;
    min-height: 0;
    padding: 0;
  }

  .temis-graph-nav--compact .temis-graph-nav__node--current,
  .temis-graph-nav--compact .temis-graph-nav__node[data-graph-state="active"] {
    block-size: var(--ds-space-phi-3, 1.625rem);
    inline-size: var(--ds-space-phi-3, 1.625rem);
  }

  .temis-graph-nav--compact .temis-graph-nav__node-label {
    block-size: 1px;
    clip: rect(0 0 0 0);
    clip-path: inset(50%);
    inline-size: 1px;
    overflow: hidden;
    position: absolute;
    white-space: nowrap;
  }

  .temis-graph-nav--compact .temis-graph-nav__node-marker {
    align-items: center;
    display: inline-flex;
    font-family: var(--ds-font-mono, ui-monospace);
    font-size: var(--ds-font-size-caption, 0.625rem);
    font-style: normal;
    font-weight: 700;
    inline-size: 100%;
    justify-content: center;
    line-height: 1;
  }

  .temis-graph-nav--compact .temis-graph-nav__index {
    border-block: var(--ds-stroke-hairline, 1px) solid
      var(--ds-color-line, currentColor);
    display: grid;
    gap: 0;
    max-block-size: calc(var(--ds-row-unit, var(--ds-grid-unit, 2.625rem)) * 4);
    overflow: auto;
  }

  .temis-graph-nav--compact .temis-graph-nav__index-link {
    align-items: center;
    border-block-end: var(--ds-stroke-hairline, 1px) solid
      var(--ds-color-line, currentColor);
    color: var(--ds-color-text, currentColor);
    display: grid;
    gap: var(--ds-space-phi-00, 0.25rem) var(--ds-space-phi-1, 0.625rem);
    grid-template-columns: var(--ds-space-phi-3, 1.625rem) minmax(0, 1fr) auto;
    min-block-size: var(--ds-row-unit, var(--ds-grid-unit, 2.625rem));
    padding-block: var(--ds-row-quarter, var(--ds-space-phi-0, 0.375rem));
    text-decoration: none;
  }

  .temis-graph-nav--compact .temis-graph-nav__index-link:last-child {
    border-block-end: 0;
  }

  .temis-graph-nav--compact .temis-graph-nav__index-link > span {
    align-items: center;
    border: var(--ds-stroke-hairline, 1px) solid
      var(--ds-color-line-strong, currentColor);
    display: inline-flex;
    font-family: var(--ds-font-mono, ui-monospace);
    font-size: var(--ds-font-size-caption, 0.625rem);
    font-weight: 700;
    justify-content: center;
    min-block-size: var(--ds-space-phi-3, 1.625rem);
  }

  .temis-graph-nav--compact .temis-graph-nav__index-link strong,
  .temis-graph-nav--compact .temis-graph-nav__index-link em {
    font-family: var(--ds-font-mono, ui-monospace);
    line-height: 1.1;
    overflow-wrap: anywhere;
  }

  .temis-graph-nav--compact .temis-graph-nav__index-link strong {
    font-size: var(--ds-font-size-meta, 0.75rem);
    text-transform: uppercase;
  }

  .temis-graph-nav--compact .temis-graph-nav__index-link em {
    color: var(--ds-color-text-muted, currentColor);
    font-size: var(--ds-font-size-caption, 0.625rem);
    font-style: normal;
    text-transform: uppercase;
  }

  .temis-graph-nav--compact
    .temis-graph-nav__index-link:is(
      :hover,
      :focus-visible,
      [data-index-state="active"],
      .temis-graph-nav__index-link--current
    ) {
    background: var(--ds-color-panel, transparent);
    color: var(--temis-graph-link-active);
  }

  .temis-graph-nav--compact
    .temis-graph-nav__index-link:is(
      :hover,
      :focus-visible,
      [data-index-state="active"],
      .temis-graph-nav__index-link--current
    )
    > span {
    border-color: var(--temis-graph-link-active);
  }

  .temis-graph-nav--compact
    .temis-graph-nav__index-link[data-index-state="neighbor"] {
    color: var(--ds-color-text, currentColor);
  }

  .temis-graph-nav--compact .temis-graph-nav__detail {
    gap: var(--ds-space-phi-1, 0.625rem);
    grid-template-columns: 1fr;
    padding-block: var(--ds-space-phi-1, 0.625rem);
  }

  .temis-graph-nav--compact .temis-graph-nav__detail h3 {
    font-family: var(--ds-font-sans, ui-sans-serif);
    font-size: var(--ds-font-size-body-lg, 1.125rem);
  }

  .temis-graph-nav--compact
    .temis-graph-nav__detail-main
    > p:not(.temis-graph-nav__detail-type) {
    font-size: var(--ds-font-size-body, 1rem);
  }

  .temis-graph-nav--compact .temis-graph-nav__detail-actions {
    justify-self: start;
  }

  .temis-graph-nav--compact .temis-graph-nav__detail-related ul {
    max-block-size: calc(var(--ds-row-unit, var(--ds-grid-unit, 2.625rem)) * 3);
    overflow: auto;
  }

  .temis-graph-nav--compact .temis-graph-nav__detail-related li {
    align-items: start;
    gap: var(--ds-space-phi-00, 0.25rem);
    grid-template-columns: 1fr;
    padding-block: var(--ds-space-phi-0, 0.375rem);
  }

  .temis-graph-nav--compact .temis-graph-nav__detail-related a {
    line-height: 1.2;
  }

  .temis-graph-nav--compact .temis-graph-nav__detail-related span {
    line-height: 1;
  }
  @media (max-width: 42rem) {
    .temis-graph-nav__map {
      aspect-ratio: 1 / 1;
    }

    .temis-graph-nav__node {
      max-width: calc(var(--ds-grid-unit, 2.625rem) * 4);
    }

    .temis-graph-nav__detail {
      grid-template-columns: 1fr;
      min-height: calc(var(--ds-row-unit, var(--ds-grid-unit, 2.625rem)) * 20);
    }

    .temis-graph-nav__detail-actions {
      justify-self: start;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .temis-graph-nav__edges path,
    .temis-graph-nav__node,
    .temis-graph-nav__node-label {
      transition: none;
    }
  }

  @media (prefers-reduced-motion: no-preference) {
    .temis-graph-nav__node-label {
      animation: temis-graph-node-idle var(--node-idle-duration, 9800ms)
        ease-in-out infinite;
      animation-delay: var(--node-idle-delay, 0ms);
    }

    .temis-graph-nav[data-graph-active] .temis-graph-nav__node-label,
    .temis-graph-nav:focus-within .temis-graph-nav__node-label {
      animation-play-state: paused;
      transform: translate(0, 0);
    }
  }

  @keyframes temis-graph-node-idle {
    0%,
    100% {
      transform: translate(0, 0);
    }

    50% {
      transform: translate(var(--node-idle-x, 0rem), var(--node-idle-y, 0rem));
    }
  }
</style>

<script>
  const graphs = document.querySelectorAll<HTMLElement>(".temis-graph-nav");

  for (const graph of graphs) {
    const nodes = [...graph.querySelectorAll<HTMLElement>("[data-node-id]")];
    const indexLinks = [
      ...graph.querySelectorAll<HTMLElement>("[data-index-node-id]"),
    ];
    const edges = [
      ...graph.querySelectorAll<SVGPathElement>("[data-edge-source]"),
    ];
    const detailPanels = [
      ...graph.querySelectorAll<HTMLElement>("[data-detail-node-id]"),
    ];
    const neighbors = new Map<string, Set<string>>();
    const initialNodeId =
      nodes.find((node) => node.getAttribute("aria-expanded") === "true")
        ?.dataset.nodeId ??
      detailPanels.find((panel) => !panel.hidden)?.dataset.detailNodeId ??
      nodes[0]?.dataset.nodeId ??
      null;
    let lockedNodeId: string | null = null;

    const setExpandedNode = (nodeId: string | null) => {
      for (const node of nodes) {
        node.setAttribute(
          "aria-expanded",
          node.dataset.nodeId === nodeId ? "true" : "false",
        );
      }

      for (const indexLink of indexLinks) {
        indexLink.setAttribute(
          "aria-expanded",
          indexLink.dataset.indexNodeId === nodeId ? "true" : "false",
        );
      }
    };

    for (const node of nodes) {
      const nodeId = node.dataset.nodeId;
      if (!nodeId) continue;
      neighbors.set(nodeId, new Set());
    }

    for (const edge of edges) {
      const source = edge.dataset.edgeSource;
      const target = edge.dataset.edgeTarget;
      if (!source || !target) continue;
      neighbors.get(source)?.add(target);
      neighbors.get(target)?.add(source);
    }

    const clearGraphState = () => {
      graph.removeAttribute("data-graph-active");
      setExpandedNode(initialNodeId);
      if (initialNodeId) showDetailPanel(initialNodeId);
      for (const node of nodes) node.removeAttribute("data-graph-state");
      for (const edge of edges) edge.removeAttribute("data-graph-state");
      for (const indexLink of indexLinks) {
        indexLink.removeAttribute("data-index-state");
      }
    };

    const showDetailPanel = (nodeId: string) => {
      for (const panel of detailPanels) {
        panel.hidden = panel.dataset.detailNodeId !== nodeId;
      }
    };

    const activateNode = (nodeId: string) => {
      const relatedNodes = neighbors.get(nodeId) ?? new Set();
      graph.dataset.graphActive = nodeId;
      setExpandedNode(nodeId);
      showDetailPanel(nodeId);

      for (const node of nodes) {
        const currentNodeId = node.dataset.nodeId;
        if (currentNodeId === nodeId) {
          node.dataset.graphState = "active";
        } else if (currentNodeId && relatedNodes.has(currentNodeId)) {
          node.dataset.graphState = "neighbor";
        } else {
          node.removeAttribute("data-graph-state");
        }
      }

      for (const indexLink of indexLinks) {
        const currentNodeId = indexLink.dataset.indexNodeId;
        if (currentNodeId === nodeId) {
          indexLink.dataset.indexState = "active";
        } else if (currentNodeId && relatedNodes.has(currentNodeId)) {
          indexLink.dataset.indexState = "neighbor";
        } else {
          indexLink.removeAttribute("data-index-state");
        }
      }

      for (const edge of edges) {
        const source = edge.dataset.edgeSource;
        const target = edge.dataset.edgeTarget;
        if (source === nodeId || target === nodeId) {
          edge.dataset.graphState = "related";
        } else {
          edge.removeAttribute("data-graph-state");
        }
      }
    };

    const unlock = () => {
      lockedNodeId = null;
      graph.removeAttribute("data-graph-locked");
      clearGraphState();
    };

    const lockNode = (nodeId: string) => {
      lockedNodeId = nodeId;
      graph.dataset.graphLocked = nodeId;
      activateNode(nodeId);
    };

    for (const node of nodes) {
      node.addEventListener("pointerenter", () => {
        if (lockedNodeId) return;
        const nodeId = node.dataset.nodeId;
        if (nodeId) activateNode(nodeId);
      });

      node.addEventListener("pointerleave", () => {
        if (!lockedNodeId) clearGraphState();
      });

      node.addEventListener("focus", () => {
        if (lockedNodeId) return;
        const nodeId = node.dataset.nodeId;
        if (nodeId) activateNode(nodeId);
      });

      node.addEventListener("blur", () => {
        if (!lockedNodeId) clearGraphState();
      });

      node.addEventListener("click", (event) => {
        const nodeId = node.dataset.nodeId;
        if (!nodeId) return;

        if (
          event.defaultPrevented ||
          event.button !== 0 ||
          event.metaKey ||
          event.ctrlKey ||
          event.shiftKey ||
          event.altKey
        ) {
          return;
        }

        event.preventDefault();
        lockNode(nodeId);
      });
    }

    for (const indexLink of indexLinks) {
      indexLink.addEventListener("pointerenter", () => {
        if (lockedNodeId) return;
        const nodeId = indexLink.dataset.indexNodeId;
        if (nodeId) activateNode(nodeId);
      });

      indexLink.addEventListener("pointerleave", () => {
        if (!lockedNodeId) clearGraphState();
      });

      indexLink.addEventListener("focus", () => {
        if (lockedNodeId) return;
        const nodeId = indexLink.dataset.indexNodeId;
        if (nodeId) activateNode(nodeId);
      });

      indexLink.addEventListener("blur", () => {
        if (!lockedNodeId) clearGraphState();
      });

      indexLink.addEventListener("click", (event) => {
        const nodeId = indexLink.dataset.indexNodeId;
        if (!nodeId) return;

        if (
          event.defaultPrevented ||
          event.button !== 0 ||
          event.metaKey ||
          event.ctrlKey ||
          event.shiftKey ||
          event.altKey
        ) {
          return;
        }

        event.preventDefault();
        lockNode(nodeId);
      });
    }

    graph.addEventListener("keydown", (event) => {
      if (event.key !== "Escape") return;
      unlock();
    });

    document.addEventListener("pointerdown", (event) => {
      if (!lockedNodeId || graph.contains(event.target as Node)) return;
      unlock();
    });
  }
</script>
