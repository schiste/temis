---
import { hashText } from "../geometry";
import { withGraphNavigationLayout } from "../layout";
import type {
  GraphNavigationMode,
  GraphNavigationNodeType,
  GraphNavigationSnapshot,
} from "../types";
import { edgePath, toVisualNode, type VisualGraphEdge } from "../visual";

export interface Props {
  graph: GraphNavigationSnapshot;
  heading?: string;
  label?: string;
  defaultMode?: GraphNavigationMode;
  showControls?: boolean;
  showDetails?: boolean;
  showLegend?: boolean;
  variant?: "default" | "compact";
}

const {
  graph,
  defaultMode = graph.scope === "global" ? "overview" : "focus",
  heading = "Content graph",
  label = "Content graph navigation",
  variant = "default",
  showControls = variant !== "compact" && graph.scope === "global",
  showDetails = true,
  showLegend = variant !== "compact",
} = Astro.props;
const showNodeMeta = variant !== "compact";
const nodeTypeLabels: Record<GraphNavigationNodeType, string> = {
  author: "Author",
  content: "Content",
  initiative: "Initiative",
  publication: "Publication",
  research_paper: "Research paper",
  tag: "Tag",
  tool: "Tool",
  topic: "Topic",
};
const nodeTypeShortLabels: Record<GraphNavigationNodeType, string> = {
  author: "A",
  content: "C",
  initiative: "I",
  publication: "P",
  research_paper: "R",
  tag: "#",
  tool: "T",
  topic: "+",
};
const nodeTypeGroupLabels: Record<GraphNavigationNodeType, string> = {
  author: "People",
  content: "Articles",
  initiative: "Initiatives",
  publication: "Publications",
  research_paper: "Publications",
  tag: "Topics",
  tool: "Tools",
  topic: "Topics",
};
const modeLabels: Record<GraphNavigationMode, string> = {
  overview: "Overview",
  content: "Content",
  focus: "Focus",
};
const modeDescriptions: Record<GraphNavigationMode, string> = {
  overview: "Initiatives, topics, tags, and major tools",
  content: "All published graph records",
  focus: "Selected node and direct neighbors",
};
const graphModes: GraphNavigationMode[] = ["overview", "content", "focus"];
const resolvedDefaultMode = graphModes.includes(defaultMode)
  ? defaultMode
  : "overview";
const laidOutGraph = withGraphNavigationLayout(graph);
const visualNodes = laidOutGraph.nodes.map(toVisualNode);
const nodesById = new Map(visualNodes.map((node) => [node.id, node]));
const edges: VisualGraphEdge[] = laidOutGraph.edges
  .map((edge): VisualGraphEdge | null => {
    const sourceNode = nodesById.get(edge.source);
    const targetNode = nodesById.get(edge.target);
    if (!sourceNode || !targetNode) return null;

    return {
      ...edge,
      modes: sourceNode.modes.filter((mode) => targetNode.modes.includes(mode)),
      path: edgePath(edge.id, sourceNode, targetNode),
      sourceNode,
      targetNode,
    };
  })
  .filter((edge): edge is VisualGraphEdge => edge !== null);
const relatedNodesById = new Map<string, typeof visualNodes>();
const relatedEdgesById = new Map<
  string,
  { edge: VisualGraphEdge; node: (typeof visualNodes)[number] }[]
>();

for (const edge of edges) {
  if (!edge.sourceNode || !edge.targetNode) continue;

  relatedNodesById.set(edge.source, [
    ...(relatedNodesById.get(edge.source) ?? []),
    edge.targetNode,
  ]);
  relatedNodesById.set(edge.target, [
    ...(relatedNodesById.get(edge.target) ?? []),
    edge.sourceNode,
  ]);
  relatedEdgesById.set(edge.source, [
    ...(relatedEdgesById.get(edge.source) ?? []),
    { edge, node: edge.targetNode },
  ]);
  relatedEdgesById.set(edge.target, [
    ...(relatedEdgesById.get(edge.target) ?? []),
    { edge, node: edge.sourceNode },
  ]);
}

function nodeSupportsMode(
  node: (typeof visualNodes)[number],
  mode: GraphNavigationMode,
) {
  if (mode === "focus") return true;
  return node.modes.includes(mode);
}

const initialDetailNodeId =
  laidOutGraph.currentNodeId && nodesById.has(laidOutGraph.currentNodeId)
    ? laidOutGraph.currentNodeId
    : (visualNodes.find((node) => nodeSupportsMode(node, resolvedDefaultMode))
        ?.id ?? visualNodes[0]?.id);
function nodeAnchorX(x: number) {
  if (x < 18) return "left";
  if (x > 82) return "right";
  return "middle";
}

function nodeAnchorY(y: number) {
  if (y < 18) return "top";
  if (y > 82) return "bottom";
  return "middle";
}

const detailPanels = showDetails
  ? visualNodes.map((node) => {
      const groupedRelatedNodes = new Map<
        string,
        (typeof visualNodes)[number][]
      >();

      for (const related of relatedEdgesById.get(node.id) ?? []) {
        const groupLabel = nodeTypeGroupLabels[related.node.type];
        groupedRelatedNodes.set(groupLabel, [
          ...(groupedRelatedNodes.get(groupLabel) ?? []),
          related.node,
        ]);
      }

      const relatedGroups = [...groupedRelatedNodes]
        .map(([groupLabel, nodes]) => ({
          groupLabel,
          nodes: nodes.sort((a, b) => {
            if (a.priority !== b.priority) return b.priority - a.priority;
            return a.label.localeCompare(b.label);
          }),
        }))
        .sort((a, b) => a.groupLabel.localeCompare(b.groupLabel));

      return {
        node,
        relatedGroups,
        relatedNodes: [...(relatedNodesById.get(node.id) ?? [])].sort(
          (a, b) => {
            if (a.priority !== b.priority) return b.priority - a.priority;
            return a.label.localeCompare(b.label);
          },
        ),
      };
    })
  : [];
const previewPanels = visualNodes
  .filter((node) => node.id !== laidOutGraph.currentNodeId)
  .map((node) => {
    const horizontal = node.visualX > 66 ? "left" : "right";
    const vertical =
      node.visualY > 70 ? "up" : node.visualY < 30 ? "down" : "middle";

    return {
      node,
      horizontal,
      primaryMeta: node.meta[0],
      vertical,
    };
  });
const detailRegionId = `temis-graph-details-${hashText(`${heading}:${label}:${laidOutGraph.generatedAt}`)}`;
const headingId = `temis-graph-heading-${hashText(`${heading}:${label}:${laidOutGraph.generatedAt}`)}`;
const presentTypes = [...new Set(visualNodes.map((node) => node.type))].sort(
  (a, b) =>
    nodeTypeGroupLabels[a].localeCompare(nodeTypeGroupLabels[b]) ||
    nodeTypeLabels[a].localeCompare(nodeTypeLabels[b]),
);
const legendTypes = presentTypes.filter(
  (type) => type !== "publication" || !presentTypes.includes("research_paper"),
);

function nodeLabelWeight(node: (typeof visualNodes)[number]) {
  if (node.id === laidOutGraph.currentNodeId) return "primary";
  if (node.type === "initiative" || node.type === "topic") return "primary";
  if (node.type === "tag" && node.priority >= 50) return "primary";
  if (node.type === "tool" && node.priority >= 60) return "primary";
  return "secondary";
}

function modeList(modes: GraphNavigationMode[]) {
  return modes.join(" ");
}
---

<nav
  class:list={[
    "temis-graph-nav",
    variant === "compact" && "temis-graph-nav--compact",
  ]}
  aria-labelledby={headingId}
  data-graph-mode={resolvedDefaultMode}
  tabindex="-1"
>
  <div class="temis-graph-nav__header">
    <h2 id={headingId}>{heading}</h2>
  </div>

  {
    showControls && (
      <div class="temis-graph-nav__controls" aria-label="Graph display">
        <div class="temis-graph-nav__mode-group" role="group" aria-label="Mode">
          {graphModes.map((mode) => (
            <button
              type="button"
              data-graph-mode-button={mode}
              aria-pressed={mode === resolvedDefaultMode ? "true" : "false"}
            >
              <span>{modeLabels[mode]}</span>
              <em>{modeDescriptions[mode]}</em>
            </button>
          ))}
        </div>
        <div
          class="temis-graph-nav__filter-group"
          role="group"
          aria-label="Node filters"
        >
          {presentTypes.map((type) => (
            <label>
              <input type="checkbox" data-graph-type-filter={type} checked />
              <span aria-hidden="true">{nodeTypeShortLabels[type]}</span>
              <strong>{nodeTypeLabels[type]}</strong>
            </label>
          ))}
        </div>
      </div>
    )
  }

  <div class="temis-graph-nav__map">
    <svg
      class="temis-graph-nav__edges"
      viewBox="0 0 100 100"
      preserveAspectRatio="none"
      aria-hidden="true"
    >
      {
        edges.map((edge) => (
          <path
            d={edge.path}
            data-edge-id={edge.id}
            data-edge-modes={modeList(edge.modes)}
            data-edge-source={edge.source}
            data-edge-target={edge.target}
          />
        ))
      }
    </svg>

    {
      visualNodes.map((node) => (
        <a
          class:list={[
            "temis-graph-nav__node",
            `temis-graph-nav__node--${node.type}`,
            node.id === laidOutGraph.currentNodeId &&
              "temis-graph-nav__node--current",
          ]}
          aria-label={`${node.label} (${nodeTypeLabels[node.type]})`}
          aria-controls={showDetails ? detailRegionId : undefined}
          aria-expanded={
            showDetails
              ? node.id === initialDetailNodeId
                ? "true"
                : "false"
              : undefined
          }
          data-node-id={node.id}
          data-node-label-weight={nodeLabelWeight(node)}
          data-node-modes={modeList(node.modes)}
          data-node-type={node.type}
          data-node-x={node.visualX}
          data-node-y={node.visualY}
          data-node-anchor-x={nodeAnchorX(node.visualX)}
          data-node-anchor-y={nodeAnchorY(node.visualY)}
          draggable="false"
          href={node.href}
          id={`graph-node-${node.slug}`}
          style={`--node-x:${node.visualX};--node-y:${node.visualY};--node-idle-x:${node.idleX}rem;--node-idle-y:${node.idleY}rem;--node-idle-duration:${node.idleDuration}ms;--node-idle-delay:${node.idleDelay}ms;${node.accent ? `--node-accent:${node.accent};` : ""}`}
        >
          <span class="temis-graph-nav__node-marker" aria-hidden="true">
            {nodeTypeShortLabels[node.type]}
          </span>
          <span class="temis-graph-nav__node-label">{node.label}</span>
        </a>
      ))
    }

    {
      previewPanels.map(({ horizontal, node, primaryMeta, vertical }) => (
        <aside
          class="temis-graph-nav__preview"
          data-preview-node-id={node.id}
          data-preview-placement-x={horizontal}
          data-preview-placement-y={vertical}
          hidden
          style={`--preview-x:${node.visualX};--preview-y:${node.visualY};`}
        >
          <button type="button" aria-label={`Close ${node.label} preview`}>
            x
          </button>
          <p>{nodeTypeLabels[node.type]}</p>
          <h3>{node.label}</h3>
          {node.description && <span>{node.description}</span>}
          {primaryMeta && (
            <dl>
              <dt>{primaryMeta.label}</dt>
              <dd>
                {primaryMeta.href ? (
                  <a href={primaryMeta.href}>{primaryMeta.value}</a>
                ) : primaryMeta.datetime ? (
                  <time datetime={primaryMeta.datetime}>
                    {primaryMeta.value}
                  </time>
                ) : (
                  primaryMeta.value
                )}
              </dd>
            </dl>
          )}
          <a href={node.href}>Open</a>
        </aside>
      ))
    }
  </div>

  {
    variant === "compact" && visualNodes.length > 1 && (
      <div class="temis-graph-nav__index" aria-label="Graph nodes">
        {visualNodes.map((node) => (
          <a
            class:list={[
              "temis-graph-nav__index-link",
              node.id === laidOutGraph.currentNodeId &&
                "temis-graph-nav__index-link--current",
            ]}
            aria-controls={showDetails ? detailRegionId : undefined}
            aria-expanded={
              showDetails
                ? node.id === initialDetailNodeId
                  ? "true"
                  : "false"
                : undefined
            }
            data-index-node-id={node.id}
            href={node.href}
          >
            <span aria-hidden="true">{nodeTypeShortLabels[node.type]}</span>
            <strong>{node.label}</strong>
            <em>{nodeTypeLabels[node.type]}</em>
          </a>
        ))}
      </div>
    )
  }

  {
    showDetails && (
      <section
        class="temis-graph-nav__details"
        aria-label="Selected graph node"
        aria-live="polite"
        id={detailRegionId}
      >
        {detailPanels.map(({ node, relatedGroups, relatedNodes }) => (
          <article
            class="temis-graph-nav__detail"
            data-detail-node-id={node.id}
            hidden={node.id !== initialDetailNodeId}
          >
            <div class="temis-graph-nav__detail-main">
              <p class="temis-graph-nav__detail-type">
                {nodeTypeLabels[node.type]}
              </p>
              <h3>{node.label}</h3>
              {node.description && <p>{node.description}</p>}
              {showNodeMeta && node.meta.length > 0 && (
                <dl class="temis-graph-nav__detail-meta">
                  {node.meta.map((item) => (
                    <div>
                      <dt>{item.label}</dt>
                      <dd>
                        {item.href ? (
                          <a href={item.href}>{item.value}</a>
                        ) : item.datetime ? (
                          <time datetime={item.datetime}>{item.value}</time>
                        ) : (
                          item.value
                        )}
                      </dd>
                    </div>
                  ))}
                </dl>
              )}
            </div>

            <div class="temis-graph-nav__detail-actions">
              <a href={node.href} aria-label={`Open ${node.label}`}>
                Open
              </a>
            </div>

            {relatedNodes.length > 0 && (
              <div class="temis-graph-nav__detail-related">
                <p>Related</p>
                {relatedGroups.map((group) => (
                  <section>
                    <h4>{group.groupLabel}</h4>
                    <ul>
                      {group.nodes.map((relatedNode) => (
                        <li>
                          <a href={relatedNode.href}>{relatedNode.label}</a>
                          <span>{nodeTypeLabels[relatedNode.type]}</span>
                        </li>
                      ))}
                    </ul>
                  </section>
                ))}
              </div>
            )}
          </article>
        ))}
      </section>
    )
  }

  {
    showLegend && legendTypes.length > 0 && (
      <ul class="temis-graph-nav__legend" aria-label="Graph legend">
        {legendTypes.map((type) => (
          <li>
            <span
              class:list={[
                "temis-graph-nav__legend-marker",
                `temis-graph-nav__legend-marker--${type}`,
              ]}
              aria-hidden="true"
            >
              {nodeTypeShortLabels[type]}
            </span>
            <strong>{nodeTypeLabels[type]}</strong>
          </li>
        ))}
      </ul>
    )
  }

  <ul class="temis-graph-nav__fallback">
    {
      visualNodes.map((node) => (
        <li>
          <div class="temis-graph-nav__fallback-head">
            <a href={node.href}>{node.label}</a>
            <span>{nodeTypeLabels[node.type]}</span>
          </div>
          {node.description && (
            <span class="temis-graph-nav__fallback-description">
              {node.description}
            </span>
          )}
        </li>
      ))
    }
  </ul>
</nav>

<style>
  .temis-graph-nav {
    --temis-graph-link-active: color-mix(
      in srgb,
      #00a66a 88%,
      var(--ds-color-text, currentColor) 12%
    );
    --temis-graph-node-muted-opacity: 0.22;
    box-shadow:
      inset 0 var(--ds-stroke-hairline, 1px) 0
        var(--ds-color-line-strong, currentColor),
      inset 0 calc(var(--ds-stroke-hairline, 1px) * -1) 0
        var(--ds-color-line-strong, currentColor);
    color: var(--ds-color-text, currentColor);
    display: grid;
    gap: 0;
    inline-size: 100%;
    max-inline-size: 100%;
    min-inline-size: 0;
    padding-block: 0;
  }

  .temis-graph-nav__header {
    align-items: center;
    box-shadow: inset 0 calc(var(--ds-stroke-hairline, 1px) * -1) 0
      var(--ds-color-line-strong, currentColor);
    display: flex;
    font-family: var(--ds-font-mono, ui-monospace);
    min-height: var(
      --ds-row-half,
      calc(var(--ds-row-unit, var(--ds-grid-unit, 2.625rem)) / 2)
    );
    padding: 0;
    text-transform: uppercase;
  }

  .temis-graph-nav__header h2 {
    align-items: center;
    display: inline-flex;
    font-size: var(--ds-font-size-meta, 0.75rem);
    line-height: 1;
    margin: 0;
    min-height: var(
      --ds-row-half,
      calc(var(--ds-row-unit, var(--ds-grid-unit, 2.625rem)) / 2)
    );
    padding-inline-end: var(--ds-space-phi-1, 0.625rem);
  }

  .temis-graph-nav__controls {
    border-block-end: var(--ds-stroke-hairline, 1px) solid
      var(--ds-color-line, currentColor);
    display: grid;
    gap: 0;
  }

  .temis-graph-nav__mode-group,
  .temis-graph-nav__filter-group {
    display: grid;
    gap: 0;
  }

  .temis-graph-nav__mode-group {
    grid-template-columns: repeat(
      auto-fit,
      minmax(calc(var(--ds-grid-unit, 2.625rem) * 4), 1fr)
    );
  }

  .temis-graph-nav__mode-group button,
  .temis-graph-nav__filter-group label {
    background: transparent;
    border: 0;
    border-block-end: var(--ds-stroke-hairline, 1px) solid
      var(--ds-color-line, currentColor);
    border-inline-end: var(--ds-stroke-hairline, 1px) solid
      var(--ds-color-line, currentColor);
    color: var(--ds-color-text, currentColor);
    display: grid;
    font: inherit;
    gap: var(--ds-space-phi-00, 0.25rem);
    min-height: var(--ds-row-unit, var(--ds-grid-unit, 2.625rem));
    padding: var(--ds-row-quarter, var(--ds-space-phi-1, 0.625rem));
    text-align: start;
  }

  .temis-graph-nav__mode-group button {
    cursor: pointer;
  }

  .temis-graph-nav__mode-group button:hover,
  .temis-graph-nav__mode-group button:focus-visible,
  .temis-graph-nav__mode-group button[aria-pressed="true"] {
    background: var(--ds-color-panel, transparent);
    color: var(--temis-graph-link-active);
  }

  .temis-graph-nav__mode-group button:focus-visible,
  .temis-graph-nav__filter-group label:has(input:focus-visible) {
    outline: var(--ds-stroke-strong, 2px) solid
      var(--ds-color-focus, currentColor);
    outline-offset: calc(var(--ds-stroke-strong, 2px) * -1);
  }

  .temis-graph-nav__mode-group span,
  .temis-graph-nav__filter-group strong {
    font-family: var(--ds-font-mono, ui-monospace);
    font-size: var(--ds-font-size-meta, 0.75rem);
    font-weight: 700;
    line-height: 1;
    text-transform: uppercase;
  }

  .temis-graph-nav__mode-group em {
    color: var(--ds-color-text-muted, currentColor);
    font-size: var(--ds-font-size-caption, 0.625rem);
    font-style: normal;
    line-height: 1.25;
  }

  .temis-graph-nav__filter-group {
    grid-template-columns: repeat(
      auto-fit,
      minmax(calc(var(--ds-grid-unit, 2.625rem) * 3), 1fr)
    );
  }

  .temis-graph-nav__filter-group label {
    align-items: center;
    cursor: pointer;
    grid-template-columns: auto auto minmax(0, 1fr);
  }

  .temis-graph-nav__filter-group input {
    accent-color: var(--temis-graph-link-active);
    margin: 0;
  }

  .temis-graph-nav__filter-group label > span {
    align-items: center;
    border: var(--ds-stroke-hairline, 1px) solid
      var(--ds-color-line-strong, currentColor);
    display: inline-flex;
    font-family: var(--ds-font-mono, ui-monospace);
    font-size: var(--ds-font-size-caption, 0.625rem);
    font-weight: 700;
    inline-size: var(--ds-space-phi-3, 1.625rem);
    justify-content: center;
    min-block-size: var(--ds-space-phi-3, 1.625rem);
  }

  .temis-graph-nav__map {
    aspect-ratio: 2.618 / 1;
    background:
      linear-gradient(
        90deg,
        color-mix(in srgb, var(--ds-color-line, currentColor) 36%, transparent)
          var(--ds-stroke-hairline, 1px),
        transparent var(--ds-stroke-hairline, 1px)
      ),
      color-mix(in srgb, var(--ds-color-panel, transparent) 50%, transparent);
    background-size: var(--ds-grid-unit, 2.625rem)
      var(--ds-row-unit, var(--ds-grid-unit, 2.625rem));
    box-sizing: border-box;
    inline-size: 100%;
    max-inline-size: 100%;
    min-height: calc(var(--ds-row-unit, var(--ds-grid-unit, 2.625rem)) * 8);
    min-inline-size: 0;
    position: relative;
  }

  .temis-graph-nav__edges {
    height: 100%;
    inset: 0;
    position: absolute;
    width: 100%;
  }

  .temis-graph-nav__edges path {
    fill: none;
    stroke: var(--ds-color-line-strong, currentColor);
    stroke-linecap: square;
    stroke-width: 0.44px;
    opacity: 0.82;
    transform-box: fill-box;
    transform-origin: center;
    transition:
      opacity 160ms ease,
      stroke-width 160ms ease,
      transform 160ms ease;
    vector-effect: non-scaling-stroke;
  }

  .temis-graph-nav__edges path[hidden],
  .temis-graph-nav__node[hidden] {
    display: none;
  }

  .temis-graph-nav__node {
    --node-accent: var(--ds-color-accent, currentColor);
    align-items: center;
    background: var(--ds-color-surface, Canvas);
    border: var(--ds-stroke-hairline, 1px) solid var(--node-accent);
    color: var(--ds-color-text, currentColor);
    cursor: grab;
    display: inline-flex;
    gap: var(--ds-space-phi-00, 0.25rem);
    font-family: var(--ds-font-mono, ui-monospace);
    font-size: var(--ds-font-size-meta, 0.75rem);
    font-weight: 700;
    inset-block-start: calc(var(--node-y) * 1%);
    inset-inline-start: calc(var(--node-x) * 1%);
    line-height: 1.1;
    max-width: calc(var(--ds-grid-unit, 2.625rem) * 5);
    min-height: var(--ds-row-unit, var(--ds-grid-unit, 2.625rem));
    min-width: 0;
    overflow-wrap: anywhere;
    padding: var(--ds-space-phi-1, 0.625rem);
    position: absolute;
    text-decoration: none;
    text-align: start;
    touch-action: none;
    text-transform: uppercase;
    transition:
      background-color 160ms ease,
      border-color 160ms ease,
      color 160ms ease,
      opacity 160ms ease,
      transform 160ms ease;
    transform: translate(
      var(--node-anchor-x, -50%),
      var(--node-anchor-y, -50%)
    );
    user-select: none;
    will-change: inset-block-start, inset-inline-start, transform;
    z-index: 2;
  }

  .temis-graph-nav__node[data-node-anchor-x="left"] {
    --node-anchor-x: 0;
  }

  .temis-graph-nav__node[data-node-anchor-x="middle"] {
    --node-anchor-x: -50%;
  }

  .temis-graph-nav__node[data-node-anchor-x="right"] {
    --node-anchor-x: -100%;
  }

  .temis-graph-nav__node[data-node-anchor-y="top"] {
    --node-anchor-y: 0;
  }

  .temis-graph-nav__node[data-node-anchor-y="middle"] {
    --node-anchor-y: -50%;
  }

  .temis-graph-nav__node[data-node-anchor-y="bottom"] {
    --node-anchor-y: -100%;
