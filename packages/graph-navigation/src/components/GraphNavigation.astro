---
import { withGraphNavigationLayout } from "../layout";
import type {
  GraphNavigationNodeType,
  GraphNavigationSnapshot,
} from "../types";

export interface Props {
  graph: GraphNavigationSnapshot;
  heading?: string;
  label?: string;
}

const {
  graph,
  heading = "Content graph",
  label = "Content graph navigation",
} = Astro.props;
const nodeTypeLabels: Record<GraphNavigationNodeType, string> = {
  author: "Author",
  content: "Content",
  tag: "Tag",
  tool: "Tool",
  topic: "Topic",
};
const laidOutGraph = withGraphNavigationLayout(graph);
const nodesById = new Map(laidOutGraph.nodes.map((node) => [node.id, node]));
const edges = laidOutGraph.edges
  .map((edge) => ({
    ...edge,
    sourceNode: nodesById.get(edge.source),
    targetNode: nodesById.get(edge.target),
  }))
  .filter((edge) => edge.sourceNode && edge.targetNode);
---

<nav class="temis-graph-nav" aria-label={label}>
  <div class="temis-graph-nav__header">
    <h2>{heading}</h2>
    <span>{laidOutGraph.scope}</span>
  </div>

  <div class="temis-graph-nav__map">
    <svg
      class="temis-graph-nav__edges"
      viewBox="0 0 100 100"
      preserveAspectRatio="none"
      aria-hidden="true"
    >
      {
        edges.map((edge) => (
          <line
            data-edge-source={edge.source}
            data-edge-target={edge.target}
            x1={edge.sourceNode?.x}
            y1={edge.sourceNode?.y}
            x2={edge.targetNode?.x}
            y2={edge.targetNode?.y}
          />
        ))
      }
    </svg>

    {
      laidOutGraph.nodes.map((node) => (
        <a
          class:list={[
            "temis-graph-nav__node",
            `temis-graph-nav__node--${node.type}`,
            node.id === laidOutGraph.currentNodeId &&
              "temis-graph-nav__node--current",
          ]}
          aria-label={`${node.label} (${nodeTypeLabels[node.type]})`}
          data-node-id={node.id}
          data-node-type={node.type}
          href={node.href}
          id={`graph-node-${node.slug}`}
          style={`--node-x:${node.x};--node-y:${node.y};${node.accent ? `--node-accent:${node.accent};` : ""}`}
        >
          <span>{node.label}</span>
        </a>
      ))
    }
  </div>

  <ul class="temis-graph-nav__fallback">
    {
      laidOutGraph.nodes.map((node) => (
        <li>
          <div class="temis-graph-nav__fallback-head">
            <a href={node.href}>{node.label}</a>
            <span>{nodeTypeLabels[node.type]}</span>
          </div>
          {node.description && (
            <span class="temis-graph-nav__fallback-description">
              {node.description}
            </span>
          )}
        </li>
      ))
    }
  </ul>
</nav>

<style>
  .temis-graph-nav {
    border-block: var(--ds-stroke-hairline, 1px) solid
      var(--ds-color-line-strong, currentColor);
    color: var(--ds-color-text, currentColor);
    display: grid;
    gap: var(--ds-space-phi-2, 1rem);
    padding-block: var(--ds-space-phi-2, 1rem);
  }

  .temis-graph-nav__header {
    align-items: center;
    display: flex;
    font-family: var(--ds-font-mono, ui-monospace);
    justify-content: space-between;
    text-transform: uppercase;
  }

  .temis-graph-nav__header h2,
  .temis-graph-nav__header span {
    font-size: var(--ds-font-size-meta, 0.75rem);
    line-height: 1;
    margin: 0;
  }

  .temis-graph-nav__header span {
    color: var(--ds-color-text-muted, currentColor);
  }

  .temis-graph-nav__map {
    aspect-ratio: 1.618 / 1;
    background:
      linear-gradient(
        90deg,
        color-mix(in srgb, var(--ds-color-line, currentColor) 36%, transparent)
          var(--ds-stroke-hairline, 1px),
        transparent var(--ds-stroke-hairline, 1px)
      ),
      color-mix(in srgb, var(--ds-color-panel, transparent) 50%, transparent);
    background-size: var(--ds-grid-unit, 2.625rem) var(--ds-grid-unit, 2.625rem);
    min-height: calc(var(--ds-grid-unit, 2.625rem) * 8);
    position: relative;
  }

  .temis-graph-nav__edges {
    height: 100%;
    inset: 0;
    position: absolute;
    width: 100%;
  }

  .temis-graph-nav__edges line {
    stroke: var(--ds-color-line-strong, currentColor);
    stroke-width: 0.28;
    opacity: 0.72;
    transform-box: fill-box;
    transform-origin: center;
    transition:
      opacity 160ms ease,
      stroke-width 160ms ease,
      transform 160ms ease;
    vector-effect: non-scaling-stroke;
  }

  .temis-graph-nav__node {
    --node-accent: var(--ds-color-accent, currentColor);
    align-items: center;
    background: var(--ds-color-surface, Canvas);
    border: var(--ds-stroke-hairline, 1px) solid var(--node-accent);
    color: var(--ds-color-text, currentColor);
    display: inline-flex;
    font-family: var(--ds-font-mono, ui-monospace);
    font-size: var(--ds-font-size-meta, 0.75rem);
    font-weight: 700;
    inset-block-start: calc(var(--node-y) * 1%);
    inset-inline-start: calc(var(--node-x) * 1%);
    line-height: 1.1;
    max-width: calc(var(--ds-grid-unit, 2.625rem) * 5);
    min-height: var(--ds-grid-unit, 2.625rem);
    padding: var(--ds-space-phi-1, 0.625rem);
    position: absolute;
    text-decoration: none;
    text-transform: uppercase;
    transition:
      background-color 160ms ease,
      border-color 160ms ease,
      color 160ms ease,
      opacity 160ms ease,
      transform 160ms ease;
    transform: translate(-50%, -50%);
  }

  .temis-graph-nav__node--content {
    --node-accent: var(--ds-color-link, var(--ds-color-accent, currentColor));
  }

  .temis-graph-nav__node--topic {
    --node-accent: var(--ds-color-accent, currentColor);
  }

  .temis-graph-nav__node--tag {
    --node-accent: var(--ds-color-text-muted, currentColor);
  }

  .temis-graph-nav__node--author {
    --node-accent: var(--ds-color-line-strong, currentColor);
  }

  .temis-graph-nav__node--tool {
    --node-accent: var(--ds-color-focus, var(--ds-color-accent, currentColor));
  }

  .temis-graph-nav__node:hover,
  .temis-graph-nav__node:focus-visible,
  .temis-graph-nav__node[data-graph-state="active"],
  .temis-graph-nav__node--current {
    background: var(--node-accent);
    color: var(--ds-color-accent-contrast, Canvas);
  }

  .temis-graph-nav__node[data-graph-state="neighbor"] {
    border-color: var(--node-accent);
    color: var(--node-accent);
    opacity: 1;
  }

  .temis-graph-nav[data-graph-active] .temis-graph-nav__node {
    opacity: 0.22;
  }

  .temis-graph-nav[data-graph-active]
    .temis-graph-nav__node[data-graph-state="active"],
  .temis-graph-nav[data-graph-active]
    .temis-graph-nav__node[data-graph-state="neighbor"] {
    opacity: 1;
  }

  .temis-graph-nav[data-graph-active] .temis-graph-nav__edges line {
    opacity: 0.08;
  }

  .temis-graph-nav[data-graph-active]
    .temis-graph-nav__edges
    line[data-graph-state="related"] {
    opacity: 0.92;
    stroke-width: 0.52;
    transform: scale(1.006);
  }

  .temis-graph-nav__fallback {
    border-block-start: var(--ds-stroke-hairline, 1px) solid
      var(--ds-color-line, currentColor);
    display: grid;
    gap: 0;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .temis-graph-nav__fallback li {
    border-block-end: var(--ds-stroke-hairline, 1px) solid
      var(--ds-color-line, currentColor);
    display: grid;
    gap: var(--ds-space-phi-00, 0.25rem);
    padding-block: var(--ds-space-phi-1, 0.625rem);
  }

  .temis-graph-nav__fallback-head {
    align-items: baseline;
    display: flex;
    gap: var(--ds-space-phi-1, 0.625rem);
    justify-content: space-between;
  }

  .temis-graph-nav__fallback a {
    font-family: var(--ds-font-mono, ui-monospace);
    font-size: var(--ds-font-size-meta, 0.75rem);
    text-transform: uppercase;
  }

  .temis-graph-nav__fallback-head span {
    color: var(--ds-color-text-muted, currentColor);
    font-family: var(--ds-font-mono, ui-monospace);
    font-size: var(--ds-font-size-micro, 0.625rem);
    text-transform: uppercase;
  }

  .temis-graph-nav__fallback-description {
    color: var(--ds-color-text-muted, currentColor);
    font-size: var(--ds-font-size-body, 1rem);
  }

  @media (max-width: 42rem) {
    .temis-graph-nav__map {
      aspect-ratio: 1 / 1;
    }

    .temis-graph-nav__node {
      max-width: calc(var(--ds-grid-unit, 2.625rem) * 4);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .temis-graph-nav__edges line,
    .temis-graph-nav__node {
      transition: none;
    }
  }
</style>

<script>
  const graphs = document.querySelectorAll<HTMLElement>(".temis-graph-nav");

  for (const graph of graphs) {
    const nodes = [...graph.querySelectorAll<HTMLElement>("[data-node-id]")];
    const edges = [
      ...graph.querySelectorAll<SVGLineElement>("[data-edge-source]"),
    ];
    const neighbors = new Map<string, Set<string>>();
    let lockedNodeId: string | null = null;

    for (const node of nodes) {
      const nodeId = node.dataset.nodeId;
      if (!nodeId) continue;
      neighbors.set(nodeId, new Set());
    }

    for (const edge of edges) {
      const source = edge.dataset.edgeSource;
      const target = edge.dataset.edgeTarget;
      if (!source || !target) continue;
      neighbors.get(source)?.add(target);
      neighbors.get(target)?.add(source);
    }

    const clearGraphState = () => {
      graph.removeAttribute("data-graph-active");
      for (const node of nodes) node.removeAttribute("data-graph-state");
      for (const edge of edges) edge.removeAttribute("data-graph-state");
    };

    const activateNode = (nodeId: string) => {
      const relatedNodes = neighbors.get(nodeId) ?? new Set();
      graph.dataset.graphActive = nodeId;

      for (const node of nodes) {
        const currentNodeId = node.dataset.nodeId;
        if (currentNodeId === nodeId) {
          node.dataset.graphState = "active";
        } else if (currentNodeId && relatedNodes.has(currentNodeId)) {
          node.dataset.graphState = "neighbor";
        } else {
          node.removeAttribute("data-graph-state");
        }
      }

      for (const edge of edges) {
        const source = edge.dataset.edgeSource;
        const target = edge.dataset.edgeTarget;
        if (source === nodeId || target === nodeId) {
          edge.dataset.graphState = "related";
        } else {
          edge.removeAttribute("data-graph-state");
        }
      }
    };

    const unlock = () => {
      lockedNodeId = null;
      graph.removeAttribute("data-graph-locked");
      clearGraphState();
    };

    for (const node of nodes) {
      node.addEventListener("pointerenter", () => {
        if (lockedNodeId) return;
        const nodeId = node.dataset.nodeId;
        if (nodeId) activateNode(nodeId);
      });

      node.addEventListener("pointerleave", () => {
        if (!lockedNodeId) clearGraphState();
      });

      node.addEventListener("focus", () => {
        if (lockedNodeId) return;
        const nodeId = node.dataset.nodeId;
        if (nodeId) activateNode(nodeId);
      });

      node.addEventListener("blur", () => {
        if (!lockedNodeId) clearGraphState();
      });

      node.addEventListener("click", (event) => {
        const nodeId = node.dataset.nodeId;
        const isTouchLike = matchMedia(
          "(hover: none), (pointer: coarse)",
        ).matches;
        if (!nodeId || !isTouchLike) return;

        if (lockedNodeId !== nodeId) {
          event.preventDefault();
          lockedNodeId = nodeId;
          graph.dataset.graphLocked = nodeId;
          activateNode(nodeId);
        }
      });
    }

    graph.addEventListener("keydown", (event) => {
      if (event.key !== "Escape") return;
      unlock();
    });

    document.addEventListener("pointerdown", (event) => {
      if (!lockedNodeId || graph.contains(event.target as Node)) return;
      unlock();
    });
  }
</script>
