{
  "name": "temis",
  "version": "0.1.0",
  "private": true,
  "description": "TEMIS static site with EmDash-managed content on Cloudflare.",
  "license": "MIT OR Apache-2.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm -r --parallel --if-present dev",
    "dev:site": "pnpm --filter @temis/site dev",
    "dev:cms": "pnpm --filter @temis/cms dev",
    "build": "pnpm --filter @temis/site build",
    "build:offline": "pnpm --filter @temis/site build:offline",
    "build:cms": "pnpm --filter @temis/cms build",
    "dev:tool-pipeline": "pnpm --filter @temis/tool-pipeline dev",
    "snapshot:pull:production": "pnpm --filter @temis/site snapshot:pull:production",
    "dev:site:production-content": "pnpm snapshot:pull:production && pnpm dev:site",
    "cms:sync:production-replica": "node ./scripts/sync-production-cms-db.mjs",
    "dev:cms:production-replica": "pnpm cms:sync:production-replica && pnpm dev:cms",
    "dev:production-replica": "pnpm cms:sync:production-replica && pnpm snapshot:pull:production && pnpm dev",
    "cms:schema:apply": "node ./apps/cms/schema/apply-schema.mjs",
    "cms:schema:apply:production": "node ./apps/cms/schema/apply-schema.mjs --production",
    "cms:schema:check": "node ./apps/cms/schema/check-schema.mjs",
    "cms:schema:check:production": "node ./apps/cms/schema/check-schema.mjs --production",
    "cms:content:normalize-editorial-blocks": "node ./apps/cms/scripts/normalize-editorial-blocks.mjs",
    "cms:content:normalize-editorial-blocks:production": "node ./apps/cms/scripts/normalize-editorial-blocks.mjs --production",
    "cms:content:migrate-seo": "node ./apps/cms/scripts/migrate-seo-to-native.mjs",
    "cms:content:migrate-seo:production": "node ./apps/cms/scripts/migrate-seo-to-native.mjs --production",
    "cms:content:retire-seo-fields": "node ./apps/cms/scripts/retire-legacy-seo-fields.mjs",
    "cms:content:retire-seo-fields:production": "node ./apps/cms/scripts/retire-legacy-seo-fields.mjs --production",
    "cms:mcp:check": "pnpm --filter @temis/cms mcp:check",
    "cms:mcp:check:auth": "pnpm --filter @temis/cms mcp:check:auth",
    "cms:mcp:check:guard": "pnpm --filter @temis/cms mcp:check:guard",
    "cms:mcp:check:production": "EMDASH_MCP_BASE_URL=https://temis-cms.christophe-henner.workers.dev pnpm --filter @temis/cms mcp:check:auth",
    "cms:mcp:token": "node ./apps/cms/scripts/emdash-mcp-token.mjs",
    "cms:mcp:token:create": "node ./apps/cms/scripts/emdash-mcp-token.mjs create",
    "cms:mcp:token:list": "node ./apps/cms/scripts/emdash-mcp-token.mjs list",
    "cms:mcp:token:revoke": "node ./apps/cms/scripts/emdash-mcp-token.mjs revoke",
    "cms:seed:validate": "pnpm --filter @temis/cms exec emdash seed --validate",
    "content:check": "node ./apps/cms/scripts/check-content-quality.mjs",
    "seed": "pnpm --filter @temis/cms seed",
    "type-check": "pnpm -r type-check",
    "format": "pnpm exec prettier --write \"**/*.{ts,js,mjs,json,jsonc,md,astro,css,yaml}\"",
    "format:check": "pnpm exec prettier --check \"**/*.{ts,js,mjs,json,jsonc,md,astro,css,yaml}\"",
    "design:check": "node ./scripts/check-design-grid.mjs",
    "deploy:cms": "pnpm --filter @temis/cms run deploy",
    "deploy:tool-pipeline": "pnpm --filter @temis/tool-pipeline run deploy"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.0",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "prettier": "^3.2.4",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^5.7.0",
    "wrangler": "^4.61.1"
  }
}
